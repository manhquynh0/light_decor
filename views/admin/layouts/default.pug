extends ../../client/layouts/default

block head
  style.
    .ai-chat-toggle { z-index: 100001 !important; }
    .ai-chat-window { z-index: 100002 !important; }

block content
  #pan.page-hero(style="padding:36px 0;")
    .container
      h1 Quản Lý Cửa Hàng
      nav.breadcrumb
        a(href="/admin/dashboard") Trang Tổng Quan
        span ›
        span Cài đặt

  .settings-page
    .container
      .settings-layout
        // SIDEBAR
        aside.settings-sidebar
          .user-card
            .user-avatar-wrap
              img#userAvatarImg.user-avatar-img(style=(user.avatar ? "display:flex;" : "display:none;") alt="Avatar" src=user.avatar)
              #avatarInitials.avatar-initials(style=(user.avatar ? "display:none;" : "display:flex;")) #{user.fullname ? user.fullname.charAt(0).toUpperCase() : 'U'}
              input#avatarUpload.avatar-upload-input(accept="image/*" type="file")
              button.avatar-edit-btn(onclick="document.getElementById('avatarUpload').click()" title="Đổi ảnh đại diện")
                svg(stroke-width="2.5" stroke="white" fill="none" viewBox="0 0 24 24" height="12" width="12")
                  path(d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7")
                  path(d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z")
            #sidebar-name.user-card-name #{user.fullname}
            .user-card-email #{user.email}
            span.user-role-badge.role-admin #{user.roleName}
        
        main.settings-main
          .settings-card
            .settings-card-body(style="padding: 28px 28px 0;")
              #adminTabs.admin-tabs
                button.admin-tab(data-sub="orders" onclick="window.location.href='/admin/orders'")
                  | Đơn hàng
                button.admin-tab(data-sub="products" onclick="window.location.href='/admin/products'")
                  | Sản phẩm
                if permissions && permissions.includes("permission")
                  button.admin-tab(data-sub="users" onclick="window.location.href='/admin/users'")
                    | Người dùng
                if permissions && permissions.includes("permission")
                  button.admin-tab(data-sub="roles" onclick="window.location.href='/admin/roles'")
                    | Phân quyền
                button.admin-tab(data-sub="categories" onclick="window.location.href='/admin/categories'")
                  | Danh mục
          block main   

  // Đưa tất cả Script vào cuối block content để đảm bảo chúng được chạy
  script(src="https://unpkg.com/filepond-plugin-image-preview/dist/filepond-plugin-image-preview.js") 
  script(src="https://unpkg.com/filepond-plugin-file-validate-type/dist/filepond-plugin-file-validate-type.js") 
  script(src="https://unpkg.com/filepond@^4/dist/filepond.js")
  script(src="https://cdn.jsdelivr.net/npm/chart.js") 
  script(src="https://cdn.jsdelivr.net/npm/just-validate@4.3.0/dist/just-validate.production.min.js")
  script(src="/assets/js/script.js")
  script.
    document.addEventListener("DOMContentLoaded", () => {
      const currentPath = window.location.pathname;
      const adminTabs = document.querySelectorAll(".admin-tab");
      adminTabs.forEach(tab => {
        const onclickAttr = tab.getAttribute("onclick");
        if (onclickAttr) {
          const match = onclickAttr.match(/'([^']+)'/);
          if (match && match[1]) {
            const targetPath = match[1];
            if (currentPath === targetPath || currentPath.startsWith(targetPath + '/')) {
              tab.classList.add("active");
            }
          }
        }
      });
    });
