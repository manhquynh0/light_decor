extend ../layouts/default
include ../mixins/option
include ../mixins/pagination.pug
block main
  // SUB: CATEGORIES
  #sub-categories.admin-sub-panel
  .table-toolbar
    .toolbar-search
      svg(
        stroke-width="2"
        stroke="currentColor"
        fill="none"
        viewBox="0 0 24 24"
        height="14"
        width="14"
      )
        circle(r="8" cy="11" cx="11")
        line(y2="16.65" x2="16.65" y1="21" x1="21")
      input(
        placeholder="Tìm danh mục..."
        type="text"
        search
      )
    .toolbar-actions
      select.btn-admin.btn-admin-outline(filter-status)
        option(value="") Tất cả
        option(value="active") Đang hoạt động
        option(value="inactive") Tạm dừng
    button.btn-admin.btn-admin-primary(onclick=`openModal('addCategoryModal', '${prefixAdmin}/categories/add')`)
      svg(
        stroke-width="2.5"
        stroke="currentColor"
        fill="none"
        viewBox="0 0 24 24"
        height="13"
        width="13"
      )
        line(y2="19" x2="12" y1="5" x1="12")
        line(y2="12" x2="19" y1="12" x1="5")
      | Thêm danh mục
  .data-table-wrap(style="border-radius:0;border:none;border-top:1px solid var(--border);")
    table.data-table
      thead
        tr
          th Tên danh mục
          th Mô tả
          th Trạng thái
          th Người Tạo
          th Người Cập Nhật
          th Thao tác

      tbody
        each item in categoryList
          tr
            td.td-bold #{item.name}
            td
              span.badge.badge-light #{item.description}
            td
              span
                if (item.status == "active")
                  .status-badge.status-active Đang hoạt động
                else if (item.status == "inactive")
                  .status-badge.status-inactive Dừng hoạt động

            td 
              div #{item.createdByFullName} 
              div.inner-time #{item.createdAtFormat}
            td
              div #{item.updatedByFullName}
              div.inner-time #{item.updatedAtFormat}
            td
              .action-btns
                if permissions && permissions.includes("order-update")
                  button.action-btn.action-btn-edit(
                      onclick=`openModal('editCategoryModal', '${prefixAdmin}/categories/edit/${item._id}')`
                  ) ✏
                if permissions && permissions.includes("delete")
                  button.action-btn.action-btn-delete(
                      data-url=`${prefixAdmin}/categories/delete/${item._id}`,
                      button-delete
                  ) 🗑
    +pagination(pagination, categoryList.length)
  // Add Category Modal
  #addCategoryModal.modal-backdrop
    .modal-box
      .modal-header
        h3 Thêm danh mục
        button.modal-close(onclick="closeModal('addCategoryModal')") ✕
      form#category-create-form
        .form-group
          label Tên danh mục
          input.form-control(
            placeholder="Vd: Sofa & Ghế"
            type="text"
            name = "name"
            id = "name"
          )
        .form-group
          label Danh mục cha
          select.form-control(
            name = "parent"
            id = "parent"
          )
            option(value="") Chọn danh mục cha
            if categoryTree
              +options(categoryTree, 0)
            else
              option(value="" disabled) No categories found (categoryTree undefined)
        .form-group
          label Mô tả
          textarea.form-control(
            placeholder="Mô tả danh mục..."
            name = "description"
          )
        .form-group
          label Trạng thái
          select.form-control(name = "status")
           option(value="active") Hoạt động
           option(value="inactive") Tạm dừng
        div(style="display:flex;gap:12px;")
          button.btn.btn-gold(
            style="flex:1;justify-content:center;"
            type="submit"
          ) Lưu danh mục
          button.btn.btn-outline-dark(
            onclick="closeModal('addCategoryModal')"
            type="button"
          ) Hủy
  // Edit Category 
  if (categoryDetail)
    #editCategoryModal.modal-backdrop
      .modal-box
        .modal-header
          h3 Chỉnh sửa danh mục
          button.modal-close(onclick="closeModal('editCategoryModal')") ✕

        form#category-edit-form
          .form-group(style="display:none")
            label ID
            input.form-control(
              type="text"
              name="_id"
              id="_id"
              value = categoryDetail._id
              hidden = true
            )
          .form-group
            label Tên danh mục
            input.form-control(
              placeholder="Vd: Sofa & Ghế"
              type="text"
              name="name"
              id="name"
              value = categoryDetail.name
            )
          .form-group
            label Danh mục cha
            select.form-control(
              name = "parent"
              id = "parent"
            )
              option(value="") Chọn danh mục cha
              +options(categoryTree, 0, categoryDetail.parent)
          .form-group
            label Mô tả
            textarea#editCategoryDesc.form-control(
                placeholder="Mô tả danh mục..."
                name="description"
              )= categoryDetail.description

          .form-group
            label Trạng thái
            select#editCategoryStatus.form-control(name="status")
              option(value="active" selected =categoryDetail.status == "active" ? true : false) Hoạt động
              option(value="inactive" selected =categoryDetail.status == "inactive" ? true : false) Tạm dừng

          div(style="display:flex;gap:12px;")
            button.btn.btn-gold(
              style="flex:1;justify-content:center;"
              type="submit"
            ) Lưu thay đổi

            button.btn.btn-outline-dark(
              type="button"
              onclick="closeModal('editCategoryModal')"
            ) Hủy
  #confirmModal.modal-backdrop
    .modal-box
      .modal-header
        h3 Xác nhận xoá
        button.modal-close(onclick="closeConfirmModal()") ✕

      p(style="margin:12px 0;") Bạn có chắc chắn muốn xoá mục này không?

      .form-group(style="display:flex;gap:12px;justify-content:center;")
        button.btn.btn-gold#confirmYes Xoá
        button.btn.btn-outline-dark(onclick="closeConfirmModal()") Huỷ

  if openAddModal
    script.
      document.addEventListener('DOMContentLoaded', function () {
        openModal('addCategoryModal');
      });
  if openEditModal
    script.
      document.addEventListener('DOMContentLoaded', function () {
        openModal('editCategoryModal');
      });
