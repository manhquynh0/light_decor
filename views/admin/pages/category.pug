extend ../layouts/default

block main
  // SUB: CATEGORIES
  #sub-categories.admin-sub-panel
  .table-toolbar
    .toolbar-search
      svg(
        stroke-width="2"
        stroke="currentColor"
        fill="none"
        viewBox="0 0 24 24"
        height="14"
        width="14"
      )
        circle(r="8" cy="11" cx="11")
        line(y2="16.65" x2="16.65" y1="21" x1="21")
      input(
        placeholder="Tìm danh mục..."
        type="text"
      )
    .toolbar-actions
      select.btn-admin.btn-admin-outline
        option(value="all") Tất cả
        option(value="active") Đang bán
        option(value="hidden") Ẩn
        option(value="out") Hết hàng
    button.btn-admin.btn-admin-primary(onclick="openModal('addCategoryModal')")
      svg(
        stroke-width="2.5"
        stroke="currentColor"
        fill="none"
        viewBox="0 0 24 24"
        height="13"
        width="13"
      )
        line(y2="19" x2="12" y1="5" x1="12")
        line(y2="12" x2="19" y1="12" x1="5")
      | Thêm danh mục
  .data-table-wrap(style="border-radius:0;border:none;border-top:1px solid var(--border);")
    table.data-table
      thead
        tr
          th Tên danh mục
          th Slug
          th Số SP
          th Trạng thái
          th Thao tác
      tbody
        tr
          td.td-bold 🛋 Sofa & Ghế
          td
            code(style="font-size:0.78rem;background:var(--light-bg);padding:2px 8px;border-radius:4px;") sofa-ghe
          td 148
          td
            span.status-badge.status-active Hiển thị
          td
            .action-btns
              button.action-btn.action-btn-edit(onclick="openEditCategoryModal('Bàn Ăn & Phòng Bếp', 'ban-an', 'Hiển thị')") ✏
              button.action-btn.action-btn-delete 🗑

  // Add Category Modal
  #addCategoryModal.modal-backdrop
    .modal-box
      .modal-header
        h3 Thêm / Sửa danh mục
        button.modal-close(onclick="closeModal('addCategoryModal')") ✕
      form
        .form-group
          label Tên danh mục
          input.form-control(
            placeholder="Vd: Sofa & Ghế"
            type="text"
          )
        .form-group
          label Slug (URL)
          input.form-control(
            placeholder="sofa-ghe"
            type="text"
          )
        .form-group
          label Ảnh sản phẩm
          div(style="display:flex;flex-direction:column;gap:12px;")
            #productImagePreview(style="display:flex;gap:8px;flex-wrap:wrap;")
            div(
              onclick="document.getElementById('productImageUpload').click()"
              style="width:80px;height:80px;border:2px dashed var(--border);border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;cursor:pointer;background:var(--light-bg);"
            )
              svg(
                stroke-width="2"
                stroke="var(--text-light)"
                fill="none"
                viewBox="0 0 24 24"
                height="24"
                width="24"
              )
                line(y2="19" x2="12" y1="5" x1="12")
                line(y2="12" x2="19" y1="12" x1="5")
            input#productImageUpload.avatar-upload-input(
              onchange="previewProductImages(event)"
              multiple=""
              accept="image/*"
              type="file"
            )
            button.btn.btn-outline-dark.btn-sm(
              onclick="document.getElementById('productImageUpload').click()"
              style="width:fit-content;"
              type="button"
            )
              svg(
                stroke-width="2"
                stroke="currentColor"
                fill="none"
                viewBox="0 0 24 24"
                height="14"
                width="14"
              )
                path(d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4")
                polyline(points="17 8 12 3 7 8")
                line(y2="15" x2="12" y1="3" x1="12")
              | Chọn ảnh
            p(style="font-size:0.75rem;color:var(--text-light);") Chọn nhiều ảnh để làm gallery. Ảnh đầu tiên sẽ là ảnh chính.
        .form-group
          label Mô tả
          textarea.form-control(
            placeholder="Mô tả danh mục..."
            rows="2"
          )
        .form-group
          label Trạng thái
          select.form-control
            option Hiển thị
            option Ẩn
        div(style="display:flex;gap:12px;")
          button.btn.btn-gold(
            style="flex:1;justify-content:center;"
            type="submit"
          ) Lưu danh mục
          button.btn.btn-outline-dark(
            onclick="closeModal('addCategoryModal')"
            type="button"
          ) Hủy
  // Edit Category Modal
  #editCategoryModal.modal-backdrop
    .modal-box
      .modal-header
        h3 Chỉnh sửa danh mục
        button.modal-close(onclick="closeModal('editCategoryModal')") ✕

      form
        .form-group
          label Tên danh mục
          input#editCategoryName.form-control(
            placeholder="Vd: Sofa & Ghế"
            type="text"
          )

        .form-group
          label Slug (URL)
          input#editCategorySlug.form-control(
            placeholder="sofa-ghe"
            type="text"
          )

        // Ảnh danh mục
        .form-group
          label Ảnh danh mục
          div(style="display:flex;flex-direction:column;gap:12px;")

            #editCategoryImagePreview(
              style="display:flex;gap:8px;flex-wrap:wrap;"
            )

            input#editCategoryImageUpload(
              type="file"
              multiple
              accept="image/*"
              style="display:none;"
              onchange="previewEditCategoryImages(event)"
            )

            button.btn.btn-outline-dark.btn-sm(
              onclick="document.getElementById('editCategoryImageUpload').click()"
              type="button"
              style="width:fit-content;"
            )
              | Chọn ảnh

            p(style="font-size:0.75rem;color:var(--text-light);")
              | Ảnh đầu tiên sẽ là ảnh chính.

        .form-group
          label Mô tả
          textarea#editCategoryDesc.form-control(
            placeholder="Mô tả danh mục..."
            rows="2"
          )

        .form-group
          label Trạng thái
          select#editCategoryStatus.form-control
            option Hiển thị
            option Ẩn

        div(style="display:flex;gap:12px;")
          button.btn.btn-gold(
            style="flex:1;justify-content:center;"
            type="submit"
          ) Lưu thay đổi

          button.btn.btn-outline-dark(
            type="button"
            onclick="closeModal('editCategoryModal')"
          ) Hủy