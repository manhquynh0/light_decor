extend ../layouts/default

block main
  // SUB: CATEGORIES
  #sub-categories.admin-sub-panel
  .table-toolbar
    .toolbar-search
      svg(
        stroke-width="2"
        stroke="currentColor"
        fill="none"
        viewBox="0 0 24 24"
        height="14"
        width="14"
      )
        circle(r="8" cy="11" cx="11")
        line(y2="16.65" x2="16.65" y1="21" x1="21")
      input(
        placeholder="Tìm danh mục..."
        type="text"
      )
    .toolbar-actions
      select.btn-admin.btn-admin-outline
        option(value="all") Tất cả
        option(value="active") Đang bán
        option(value="hidden") Ẩn
        option(value="out") Hết hàng
    button.btn-admin.btn-admin-primary(onclick="openModal('addCategoryModal','/admin/categories/add')")
      svg(
        stroke-width="2.5"
        stroke="currentColor"
        fill="none"
        viewBox="0 0 24 24"
        height="13"
        width="13"
      )
        line(y2="19" x2="12" y1="5" x1="12")
        line(y2="12" x2="19" y1="12" x1="5")
      | Thêm danh mục
  .data-table-wrap(style="border-radius:0;border:none;border-top:1px solid var(--border);")
    table.data-table
      thead
        tr
          th Tên danh mục
          th Mô tả
          th Số SP
          th Trạng thái
          th Người Tạo
          th Người Cập Nhật
          th Thao tác

      tbody
        tr
          td.td-bold 🛋 Sofa & Ghế
          td
            code(style="font-size:0.78rem;background:var(--light-bg);padding:2px 8px;border-radius:4px;") Mô tả
          td 148
          td
            span.status-badge.status-active Hiển thị
          td Nguyễn Văn A
          td Nguyễn Văn B
          td
            .action-btns
              button.action-btn.action-btn-edit(onclick="openEditCategoryModal('Bàn Ăn & Phòng Bếp', 'ban-an', 'Hiển thị')") ✏
              button.action-btn.action-btn-delete 🗑

  // Add Category Modal
  #addCategoryModal.modal-backdrop
    .modal-box
      .modal-header
        h3 Thêm danh mục
        button.modal-close(onclick="closeModal('addCategoryModal')") ✕
      form#category-create-form
        .form-group
          label Tên danh mục
          input.form-control(
            placeholder="Vd: Sofa & Ghế"
            type="text"
            name = "name"
            id = "name"
          )
        .form-group
          label Ảnh danh mục
          input(
            accept="image/*"
            type="file"
            filepond-image
            name="avatar"
          )
        .form-group
          label Mô tả
          textarea.form-control(
            placeholder="Mô tả danh mục..."
            rows="2"
            name = "description"
          )
        .form-group
          label Trạng thái
          select.form-control(name = "status")
            option Đang hoạt động
            option Tạm dừng
        div(style="display:flex;gap:12px;")
          button.btn.btn-gold(
            style="flex:1;justify-content:center;"
            type="submit"
          ) Lưu danh mục
          button.btn.btn-outline-dark(
            onclick="closeModal('addCategoryModal')"
            type="button"
          ) Hủy
  // Edit Category Modal
  #editCategoryModal.modal-backdrop
    .modal-box
      .modal-header
        h3 Chỉnh sửa danh mục
        button.modal-close(onclick="closeModal('editCategoryModal')") ✕

      form
        .form-group
          label Tên danh mục
          input#editCategoryName.form-control(
            placeholder="Vd: Sofa & Ghế"
            type="text"
          )
        .form-group
          label Ảnh danh mục
          input(
            accept="image/*"
            type="file"
            filepond-image
            name="editAvatar"
          )
        .form-group
          label Mô tả
          textarea#editCategoryDesc.form-control(
            placeholder="Mô tả danh mục..."
            rows="2"
          )

        .form-group
          label Trạng thái
          select#editCategoryStatus.form-control
            option Hoạt động
            option Ngừng hoạt động

        div(style="display:flex;gap:12px;")
          button.btn.btn-gold(
            style="flex:1;justify-content:center;"
            type="submit"
          ) Lưu thay đổi

          button.btn.btn-outline-dark(
            type="button"
            onclick="closeModal('editCategoryModal')"
          ) Hủy

  if openAddModal
    script.
      document.addEventListener('DOMContentLoaded', function () {
        openModal('addCategoryModal');
      });