extend ../layouts/default
block main
  // SUB: PRODUCTS
  #sub-products.admin-sub-panel
  .table-toolbar
    .toolbar-search
      svg(
        stroke-width="2"
        stroke="currentColor"
        fill="none"
        viewBox="0 0 24 24"
        height="14"
        width="14"
      )
        circle(r="8" cy="11" cx="11")
        line(y2="16.65" x2="16.65" y1="21" x1="21")
      input(
        placeholder="Tìm sản phẩm..."
        type="text"
        search
      )
    .toolbar-actions
      select.btn-admin.btn-admin-outline(filter-status)
        option(value="all") Tất cả
        option(value="stock") Đang bán
        option(value="out stock") Hết hàng
      button.btn-admin.btn-admin-primary(onclick="openModal('addProductModal', '/admin/products/add')")
        svg(
          stroke-width="2.5"
          stroke="currentColor"
          fill="none"
          viewBox="0 0 24 24"
          height="13"
          width="13"
        )
          line(y2="19" x2="12" y1="5" x1="12")
          line(y2="12" x2="19" y1="12" x1="5")
        | Thêm sản phẩm
  .data-table-wrap(style="border-radius:0;border:none;border-top:1px solid var(--border);")
    table.data-table
      thead
        tr
          th Hình ảnh
          th Tên
          th Danh mục
          th Giá
          th Tồn kho
          th Trạng thái
          th Thao tác
      tbody
        each item in product
          tr
            td
                div(
                  style="width:44px;height:44px;border-radius:8px;background:var(--light-bg);display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0;border-radius:4px;overflow:hidden;"
                ) 
                  img(src= item.avatar alt="" style="width:100%;height:100%;object-fit:cover;")
            td 
              span.td-bold #{item.name}
            td #{item.category ? item.category.name : ""}
            td.td-bold #{Number(item.priceNEW).toLocaleString("vi-VN")} ₫
            td #{item.stock}
            td
              span
                if (item.status == "stock")
                  .status-badge.status-active Còn hàng
                else if (item.status == "out stock")
                  .status-badge.status-inactive Hết hàng
            td
              .action-btns
                button.action-btn.action-btn-edit(onclick=`openModal('editProductModal', '/admin/products/edit/${item._id}')`) ✏
                button.action-btn.action-btn-delete(
                  data-url=`/admin/products/delete/${item._id}`,
                  button-delete
                ) 🗑
  .table-pagination
    span Hiển thị 1–5 / 486 sản phẩm
    .pagination-btns
      button.page-num.active 1
      button.page-num 2
      button.page-num 3

  // Add Product Modal
  #addProductModal.modal-backdrop
    .modal-box
      .modal-header
        h3 Thêm sản phẩm
        button.modal-close(onclick="closeModal('addProductModal')") ✕
      form#product-create-form
        .form-group
          label Tên sản phẩm
          input.form-control(
            placeholder="Vd: Sofa góc L Velvet Teal"
            type="text"
            name = "name"
            id = "name"
          )
        .form-row(style="margin-bottom:20px;")
          .form-group(style="margin:0;")
            label Danh mục
            select.form-control(name ="category" id="category")
              each item in categories
                option(value = item.id) #{item.name}
          .form-group(style="margin:0;")
            label Giá bán (₫)
            input.form-control(
              placeholder="0"
              name = "priceNEW"
              id = "priceNEW"
            )
        .form-row(style="margin-bottom:20px;")
          .form-group(style="margin:0;")
            label Tồn kho
            input.form-control(
              placeholder="0"
              type="number"
              name = "stock"
              id = "stock"
            )
          .form-group(style="margin:0;")
            label Giá gốc (₫)
            input.form-control(
              placeholder="Để trống nếu không giảm giá"
              type="number"
              name = "priceOLD"
              id = "priceOLD"
            )
        .form-group
          label Ảnh đại diện
          input(
            accept="image/*"
            type="file"
            name="avatar"
            id="avatar"
            required
            filepond-image
          )
        .form-group
          label Ảnh sản phẩm (nhiều ảnh)
          input(
            accept="image/*"
            type="file"
            filepond-image-multi
            name="images"
            id="images"
            multiple
          )
        .form-group
          label Mô tả
          textarea.form-control(
            placeholder="Mô tả sản phẩm..."
            rows="3"
            name = "description"
            id = "description"
          )
        .form-group
          label Trạng thái
          select.form-control(name = "status" id="status")
            option(value="stock") Đang bán
            option(value="out stock") Hết hàng
        div(style="display:flex;gap:12px;")
          button.btn.btn-gold(
            style="flex:1;justify-content:center;"
            type="submit"
          ) Lưu sản phẩm
          button.btn.btn-outline-dark(
            onclick="closeModal('addProductModal')"
            type="button"
          ) Hủy
  if (openEditModal)
    #editProductModal.modal-backdrop
      .modal-box
        .modal-header
          h3 Chỉnh sửa sản phẩm
          button.modal-close(onclick="closeModal('editProductModal')") ✕

        form#product-edit-form
          .form-group(style="display:none")
            label ID
            input.form-control(
              type="text"
              name="_id"
              id="_id"
              value = productDetail._id
              hidden = true
            )
          // Tên sản phẩm
          .form-group
            label Tên sản phẩm
            input.form-control(
              placeholder="Vd: Sofa góc L Velvet Teal"
              type="text"
              name = "name"
              id = "name"
              value = productDetail.name
            )

          
          .form-row(style="margin-bottom:20px;")
            .form-group(style="margin:0;")
              label Danh mục
              select.form-control(name = "category" id="category")
                each item in categories
                  option(value = item.id) #{item.name}

            .form-group(style="margin:0;")
              label Giá bán (₫)
              input.form-control(
                placeholder="0"
                type="number"
                value = productDetail.priceNEW
              )

          // Tồn kho + Giá gốc
          .form-row(style="margin-bottom:20px;")
            .form-group(style="margin:0;")
              label Tồn kho
              input.form-control(
                placeholder="0"
                type="number"
                value = productDetail.stock
              )

            .form-group(style="margin:0;")
              label Giá gốc (₫)
              input.form-control(
                placeholder="Để trống nếu không giảm giá"
                type="number"
                value = productDetail.priceOLD
              )

      
          .form-group
            label Ảnh đại diện
            div.inner-upload-image(image-default=productDetail.avatar)
              input(
                type="file"
                id="avatar"
                name="avatar"
                accept="image/*"
                filepond-image
                )
          .form-group
              label Ảnh sản phẩm (nhiều ảnh)
              div(list-image-default=JSON.stringify(productDetail.images))
                input(
                  type="file"
                  id="images"
                  name="images"
                  multiple
                  accept="image/*"
                  filepond-image-multi
                )

          .form-group
            label Mô tả
            textarea#editProductDesc.form-control(
                placeholder="Mô tả sản phẩm..."
                name="description"
              )= productDetail.description
          // Trạng thái
          .form-group
            label Trạng thái
            select.form-control(name = "status" id="status")
              option(value="stock" selected = productDetail.status == "stock" ? true : false) Đang bán
              option(value="out stock" selected = productDetail.status == "out stock" ? true : false) Hết hàng

          // Button
          div(style="display:flex;gap:12px;")
            button.btn.btn-gold(
              style="flex:1;justify-content:center;"
              type="submit"
            ) Lưu thay đổi

            button.btn.btn-outline-dark(
              type="button"
              onclick="closeModal('editProductModal')"
            ) Hủy
  #confirmModal.modal-backdrop
      .modal-box
        .modal-header
          h3 Xác nhận xoá
          button.modal-close(onclick="closeConfirmModal()") ✕
        p(style="margin:12px 0;") Bạn có chắc chắn muốn xoá mục này không?

        .form-group(style="display:flex;gap:12px;justify-content:center;")
          button.btn.btn-gold#confirmYes Xoá
          button.btn.btn-outline-dark(onclick="closeConfirmModal()") Hủy
  if openAddModal
    script.
      document.addEventListener('DOMContentLoaded', function () {
        openModal('addProductModal');
      });
  if openEditModal
    script.
      document.addEventListener('DOMContentLoaded', function () {
        openModal('editProductModal');
      });
    