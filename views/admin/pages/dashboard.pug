extend ../layouts/default

block main
  #panel-admin.settings-panel

  .admin-stats-grid
    .admin-stat-card
      .stat-icon.green
        svg(
          stroke-width="2"
          stroke="currentColor"
          fill="none"
          viewBox="0 0 24 24"
          height="22"
          width="22"
        )
          path(d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z")
          line(y2="6" x2="21" y1="6" x1="3")
          path(d="M16 10a4 4 0 0 1-8 0")
      .stat-info
        .stat-val #{overview.totalOrder}
        .stat-label Tổng đơn hàng
        span.stat-change.up ↑ 12% tháng này
    .admin-stat-card
      .stat-icon.gold
        svg(
          stroke-width="2"
          stroke="currentColor"
          fill="none"
          viewBox="0 0 24 24"
          height="22"
          width="22"
        )
          line(y2="23" x2="12" y1="1" x1="12")
          path(d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6")
      .stat-info
        .stat-val #{overview.totalPrice.toLocaleString("vi-VN")} ₫
        .stat-label Doanh thu tháng
        span.stat-change.up ↑ 8.4% so với tháng trước

    .admin-stat-card
      .stat-icon.blue
        svg(
          stroke-width="2"
          stroke="currentColor"
          fill="none"
          viewBox="0 0 24 24"
          height="22"
          width="22"
        )
          path(d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2")
          circle(r="4" cy="7" cx="12")
      .stat-info
        .stat-val #{overview.totalUser}
        .stat-label Người dùng
        span.stat-change.up ↑ 24 mới hôm nay

    .admin-stat-card
      .stat-icon.red
        svg(
          stroke-width="2"
          stroke="currentColor"
          fill="none"
          viewBox="0 0 24 24"
          height="22"
          width="22"
        )
          path(d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z")
      .stat-info
        .stat-val #{overview.totalProduct}
        .stat-label Sản phẩm
        span.stat-change.down ↓ 3 hết hàng

  .chart-area
    .chart-head
      h2.inner-title Biểu đồ doanh thu
      .inner-filter
        input(
          type="month"
          name=""
        )
    .inner-chart
      canvas(id="revenue-chart")

  .admin-panel(style="margin-top:24px; padding:20px;")
    .panel-header(style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;")
      h3(style="font-size:1.1rem; font-weight:700; color:var(--white); margin:0;") Đơn hàng mới gần đây
      a(href=`${prefixAdmin}/orders` style="font-size:0.85rem; color:var(--accent); text-decoration:none; font-weight:600;") Xem tất cả →
    .data-table-wrap(style="border-radius:var(--radius-md); border:1px solid var(--border); overflow:hidden;")
      table.data-table(style="width:100%; border-collapse:collapse;")
        thead
          tr(style="background:rgba(255,255,255,0.02);")
            th(style="padding:14px; text-align:left; font-size:0.85rem; color:var(--text-light); font-weight:600;") Mã đơn
            th(style="padding:14px; text-align:left; font-size:0.85rem; color:var(--text-light); font-weight:600;") Khách hàng
            th(style="padding:14px; text-align:left; font-size:0.85rem; color:var(--text-light); font-weight:600;") Ngày đặt
            th(style="padding:14px; text-align:left; font-size:0.85rem; color:var(--text-light); font-weight:600;") Tổng tiền
            th(style="padding:14px; text-align:left; font-size:0.85rem; color:var(--text-light); font-weight:600;") Thanh toán
            th(style="padding:14px; text-align:center; font-size:0.85rem; color:var(--text-light); font-weight:600;") Đơn hàng
        tbody
          each item in ordersNew
            tr(style="border-top:1px solid var(--border); transition:all 0.2s ease;")
              td(style="padding:14px; font-size:0.9rem; font-weight:700; color:var(--accent);") #{item.orderCode}
              td(style="padding:14px; font-size:0.9rem; color:var(--white);") #{item.firstName + " " + item.lastName}
              td(style="padding:14px; font-size:0.9rem; color:var(--text-mid);") #{item.createdAtFormat}
              td(style="padding:14px; font-size:0.9rem; font-weight:700; color:var(--white);") #{item.total.toLocaleString("vi-VN")} ₫
              td(style="padding:14px;")
                if(item.paymentStatus =="paid")
                  span(style="padding : 10px; border-radius:999px; font-size:0.75rem; background:rgba(144, 238, 144, 0.1); color:green; font-weight:700;")  Đã thanh toán
                else
                  span(style="padding : 10px; border-radius:999px; font-size:0.75rem; background:rgba(255, 99, 71, 0.1); color:red; font-weight:700;")  Chưa thanh toán

              td(style="padding:5px; text-align:center;")
                if(item.status == "initial")
                  span(style="padding:6px 14px; border-radius:999px; font-size:0.75rem; background:rgba(59, 130, 246, 0.15); color:#2563eb; font-weight:700;") Khởi tạo
                else if(item.status == "cancelled")
                  span(style="padding:6px 14px; border-radius:999px; font-size:0.75rem; background:rgba(239, 68, 68, 0.15); color:#dc2626; font-weight:700;") Đã hủy
                else if(item.status == "shipping")
                  span(style="padding:6px 14px; border-radius:999px; font-size:0.75rem; background:rgba(245, 158, 11, 0.15); color:#d97706; font-weight:700;") Đang giao hàng
                else if(item.status == "delivered")
                  span(style="padding:6px 14px; border-radius:999px; font-size:0.75rem; background:rgba(16, 185, 129, 0.15); color:#059669; font-weight:700;") Đã giao hàng
