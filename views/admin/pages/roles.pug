extend ../layouts/default
block main
  if permissions && permissions.includes("permission")
    // SUB: ROLES
    #sub-roles.admin-sub-panel
    .table-toolbar(style="justify-content:flex-end;")
      button.btn-admin.btn-admin-primary(onclick="openModal('addRoleModal', '/admin/roles/add')")
        svg(
          stroke-width="2.5"
          stroke="currentColor"
          fill="none"
          viewBox="0 0 24 24"
          height="13"
          width="13"
          
        )
          line(y2="19" x2="12" y1="5" x1="12")
          line(y2="12" x2="19" y1="12" x1="5")
        | Tạo vai trò mới
  div(style="display:flex;flex-direction:column;gap:16px;padding-top:8px;")
    each item in rolelist
      div(style="background:var(--off-white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:20px 24px;")
        div(style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px;")
          div(style="display:flex;align-items:center;gap:10px;")
            div(style="width:36px;height:36px;background:var(--primary);border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--accent);")
              svg(
                stroke-width="2"
                stroke="currentColor"
                fill="none"
                viewBox="0 0 24 24"
                height="16"
                width="16"
              )
                path(d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z")
            div
              strong(style="font-size:0.95rem;color:var(--text-dark);") #{item.name}
              p(style="font-size:0.78rem;color:var(--text-light);") #{item.description}
          div(style="display:flex;gap:8px;")
            button.action-btn.action-btn-edit(onclick=`openModal('editRoleModal', '/admin/roles/edit/${item._id}')`) ✏
            button.action-btn.action-btn-delete(
                  data-url=`/admin/roles/delete/${item._id}`,
                  button-delete
                ) 🗑
      div(style="display:flex;flex-wrap:wrap;gap:6px;")
       each perm in permissionList
        if item.permissions.includes(perm.value)
          span(style="padding:4px 10px;background:rgba(9, 235, 103, 0.12);color:#27ae60;border-radius:999px;font-size:0.72rem;font-weight:700;") ✓ #{perm.label}
        else
          span(style="padding:4px 10px;background:rgba(225, 28, 31, 0.12);color:red;border-radius:999px;font-size:0.72rem;font-weight:700;") ✗ #{perm.label}

  // Add Role Modal
  #addRoleModal.modal-backdrop
    .modal-box
      .modal-header
        h3 Tạo vai trò mới
        button.modal-close(onclick="closeModal('addRoleModal')") ✕
      form#role-create-form
        .form-group
          label Tên vai trò
          input.form-control(
            placeholder="Vd: Nhà kho"
            type="text"
            id = "name"
            name = "name"
          )
        .form-group
          label Mô tả
          input.form-control(
            placeholder="Mô tả ngắn về vai trò..."
            type="text"
            id = "description"
            name = "description"
          )
        p(style="font-size:0.82rem;font-weight:800;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-light);margin-bottom:12px;") Quyền hạn
        div(style="display:flex;flex-direction:column;gap:8px;margin-bottom:20px;")
          each item in permissionList
            label(style="display:flex;align-items:center;gap:10px;font-size:0.88rem;")
              input(type="checkbox" name = "permissions" value = item.value)
              | #{item.label}
        div(style="display:flex;gap:12px;")
          button.btn.btn-gold(
            style="flex:1;justify-content:center;"
            type="submit"
          ) Tạo vai trò
          button.btn.btn-outline-dark(
            onclick="closeModal('addRoleModal')"
            type="button"
          ) Hủy

  // Edit Role Modal
  if(openEditModal)
    #editRoleModal.modal-backdrop
      .modal-box
        .modal-header
          h3 Chỉnh sửa vai trò
          button.modal-close(onclick="closeModal('editRoleModal')") ✕
        form#role-edit-form
          .form-group(style="display:none")
            label ID
            input.form-control(
              type="text"
              name="_id"
              id="_id"
              value = roleDetail._id
              hidden = true
            )
          .form-group
            label Tên vai trò
            input.form-control(
              type="text"
              name="name"
              id="name"
              value = roleDetail.name
            )
          .form-group
            label Mô tả
            input.form-control(
              type="text"
              name="description"
              id="description"
              value = roleDetail.description
            )
          p(style="font-size:0.82rem;font-weight:800;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-light);margin-bottom:12px;") Quyền hạn
          div(style="display:flex;flex-direction:column;gap:8px;margin-bottom:20px;")
            each item in permissionList
              label(style="display:flex;align-items:center;gap:10px;font-size:0.88rem;")
                input(
                  type="checkbox"
                  name="permissions"
                  value=item.value
                  checked = roleDetail.permissions.includes(item.value)
                )
                | #{item.label}
          div(style="display:flex;gap:12px;")
            button.btn.btn-gold(
              style="flex:1;justify-content:center;"
              type="submit"
            ) Lưu thay đổi
            button.btn.btn-outline-dark(
              onclick="closeModal('editRoleModal')"
              type="button"
            ) Hủy
  #confirmModal.modal-backdrop
      .modal-box
        .modal-header
          h3 Xác nhận xoá
          button.modal-close(onclick="closeConfirmModal()") ✕
        p(style="margin:12px 0;") Bạn có chắc chắn muốn xoá mục này không?

        .form-group(style="display:flex;gap:12px;justify-content:center;")
          button.btn.btn-gold#confirmYes Xoá
          button.btn.btn-outline-dark(onclick="closeConfirmModal()") Hủy
  if openAddModal
    script.
      document.addEventListener('DOMContentLoaded', function () {
        openModal('addRoleModal');
      });
  if openEditModal
    script.
      document.addEventListener('DOMContentLoaded', function () {
        openModal('editRoleModal');
      });