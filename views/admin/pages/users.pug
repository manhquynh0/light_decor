extend ../layouts/default
block main
  // SUB: USERS
  #sub-users.admin-sub-panel
  .table-toolbar
    .toolbar-search
      svg(
        stroke-width="2"
        stroke="currentColor"
        fill="none"
        viewBox="0 0 24 24"
        height="14"
        width="14"
      )
        circle(r="8" cy="11" cx="11")
        line(y2="16.65" x2="16.65" y1="21" x1="21")
      input(
        placeholder="Tìm người dùng..."
        type="text"
        search
      )
    .toolbar-actions
      .toolbar-actions
        select.btn-admin.btn-admin-outline(filter-role)
          each item in roleList
            option(value=item._id) #{item.name}
      button.btn-admin.btn-admin-primary(onclick="openModal('addUserModal', '/admin/users/add')")
        svg(
          stroke-width="2.5"
          stroke="currentColor"
          fill="none"
          viewBox="0 0 24 24"
          height="13"
          width="13"
        )
          line(y2="19" x2="12" y1="5" x1="12")
          line(y2="12" x2="19" y1="12" x1="5")
        | Thêm người dùng
  .data-table-wrap(style="border-radius:0;border:none;border-top:1px solid var(--border);")
    table.data-table
      thead
        tr
          th Ảnh đại diện
          th Người dùng
          th Email
          th Ngày tham gia
          th Đơn hàng
          th Vai trò
          th Thao tác
      tbody
        each item in accountList
          tr
            td
              if item.avatar
                img(src=item.avatar, alt="", style="width:40px;height:40px;object-fit:cover;border-radius:50%;")
            td #{item.firstname} #{item.lastname}
            td #{item.email}
            td #{item.createdAt.toLocaleString("vi-VN")}
            td 0
            td #{item.role ? item.role.name : "Chưa có vai trò"}  
            td
              .action-btns
                button.action-btn.action-btn-edit(onclick=`openModal('editUserModal', '/admin/users/edit/${item._id}')`) ✏
                button.action-btn.action-btn-delete(
                  data-url=`/admin/users/delete/${item._id}`,
                  button-delete
                ) 🗑
  .table-pagination
    span Hiển thị 1–5 / 3.421 người dùng
    .pagination-btns
      button.page-num.active 1
      button.page-num 2
      button.page-num 3

  // Add User Modal
  #addUserModal.modal-backdrop
    .modal-box
      .modal-header
        h3 Thêm người dùng mới
        button.modal-close(onclick="closeModal('addUserModal')") ✕
      form#user-create-form
        .form-row(style="margin-bottom:20px;")
          .form-group(style="margin:0;")
            label Họ
            input.form-control(
              placeholder="Nguyễn"
              type="text"
              id = "firstname"
              name = "firstname"
              required
            )
          .form-group(style="margin:0;")
            label Tên
            input.form-control(
              placeholder="Văn A"
              type="text"
              name="lastname"
              required
              id = "lastname"
            )
        .form-group
          label Email
          input.form-control(
            placeholder="email@example.com"
            type="email"
            id = "email"
            name = "email"
            required
          )
        .form-group
          label Số điện thoại 
          input.form-control(
            placeholder="0123456789"
            type="text"
            id = "phone"
            name = "phone"
            required
          )
        .form-group
          label Mật khẩu 
          input.form-control(
            placeholder="Tối thiểu 8 ký tự"
            type="password"
            id = "password"
            name = "password"
            required
          )
        .form-row(style="margin-bottom:20px;")
          .form-group(style="margin:0;")
            label Vai trò
            select.form-control(id ="role" name ="role" )
              each item in roleList
                option(value=item._id) #{item.name}
         
        .form-group
          label Ảnh đại diện
          input(
            accept="image/*"
            type="file"
            filepond-image
            name="avatar"
            id = "avatar"
          )
        div(style="display:flex;gap:12px;")
          button.btn.btn-gold(
            style="flex:1;justify-content:center;"
            type="submit"
          ) Tạo tài khoản
          button.btn.btn-outline-dark(
            onclick="closeModal('addUserModal')"
            type="button"
          ) Hủy
  if (accountDetail)
    #editUserModal.modal-backdrop
      .modal-box
        .modal-header
          h3 Chỉnh sửa người dùng
          button.modal-close(onclick="closeModal('editUserModal')") ✕

        form#user-edit-form
          .form-group(style="display:none")
            label ID
            input.form-control(
              type="text"
              name="_id"
              id="_id"
              value = accountDetail._id
              hidden = true
            )
          .form-row(style="margin-bottom:20px;")
            .form-group(style="margin:0;")
              label Họ
              input.form-control(
                placeholder="Nguyễn"
                type="text"
                value = accountDetail.firstname
                id = "firstname"
                name = "firstname"
              )
            .form-group(style="margin:0;")
              label Tên
              input.form-control(
                placeholder="Văn A"
                type="text"
                value = accountDetail.lastname
                id = "lastname"
                name = "lastname"
              )
             
          .form-group
            label Email
            input.form-control(
              placeholder="email@example.com"
              type="email"
              value = accountDetail.email
              id = "email"
              name = "email"
            )
          .form-group
            label Số điện thoại
            input.form-control(
              placeholder="0123456789"
              type="text"
              value = accountDetail.phone
              id = "phone"
              name = "phone"
            )
          .form-group
            label Mật khẩu mới
            input.form-control(
              placeholder="Để trống nếu không đổi"
              type="password"
              id = "password"
              name = "password"
            )

          .form-row(style="margin-bottom:20px;")
            .form-group(style="margin:0;")
              label Vai trò
              select.form-control(id ="role" name ="role")
                each item in roleList
                  option(value=item._id
                      selected=String(item._id) === String(accountDetail.role)
                  ) #{item.name}

          .form-group
            label Ảnh đại diện
            div.inner-upload-image(image-default=accountDetail.avatar)
              input(
                type="file"
                id="avatar"
                name="avatar"
                accept="image/*"
                filepond-image
              )
          div(style="display:flex;gap:12px;")
            button.btn.btn-gold(
              style="flex:1;justify-content:center;"
              type="submit"
            ) Lưu thay đổi

            button.btn.btn-outline-dark(
              type="button"
              onclick="closeModal('editUserModal')"
            ) Hủy
  #confirmModal.modal-backdrop
    .modal-box
      .modal-header
        h3 Xác nhận xoá
        button.modal-close(onclick="closeConfirmModal()") ✕

      p(style="margin:12px 0;") Bạn có chắc chắn muốn xoá mục này không?

      .form-group(style="display:flex;gap:12px;justify-content:center;")
        button.btn.btn-gold#confirmYes Xoá
        button.btn.btn-outline-dark(onclick="closeConfirmModal()") Hủy
  if openAddModal
    script.
      document.addEventListener('DOMContentLoaded', function () {
        openModal('addUserModal');
      })
  if openEditModal
    script.
      document.addEventListener('DOMContentLoaded', function () {
        openModal('editUserModal');
      })