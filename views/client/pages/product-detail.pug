extends ../layouts/default.pug

block content
  .container(style="padding-top:20px;")
    nav.breadcrumb(style="background:none;padding:0;")

  // Product detail
  section.container
    .pd-wrap
      // LEFT: 
      .pd-gallery
        #pdMainImg.pd-main-img
          img#pdMainImgEl(
            alt=""
            src=product.avatar
            )
        #pdThumbs.pd-thumbs
          .pd-thumb.active(data-src=product.avatar)
            img(src=product.avatar)
          if product.images
            each item in product.images
              .pd-thumb(data-src=item)
                img(src=item)
         
      // RIGHT: Info
      .pd-info
        div
          p.pd-category #{product.category ? product.category.map(c => c.name).join(", ") : ""}
          h1.pd-name #{product.name}
        .pd-stars
          span.stars ★★★★★
          span 4.9 (128 đánh giá)
          span(style="color:#2a9d5c;font-weight:600;") · Còn hàng
        .pd-price-wrap
          span.pd-price-new #{Number(product.priceNEW).toLocaleString('vi-VN')} ₫
          span.pd-price-old #{Number(product.priceOLD).toLocaleString('vi-VN')} ₫
          span.pd-save - #{Number(product.priceOLD) > 0 ? Math.floor(((Number(product.priceOLD) - Number(product.priceNEW)) / Number(product.priceOLD)) * 100) : 0}%
        p(style="font-size:.9rem;color:var(--text-mid);line-height:1.8;")
          | #{product.description}
        .pd-divider
        // Color selection
        div
          p.pd-label
            | Màu sắc : 
            strong#colorLabel(style="color:yellow;font-weight:800;") #{product.colorIndex}

        // Size selection
        div
          p.pd-label
            | Kích thước
          .pd-sizes
            button.pd-size-btn.active(
              onclick="selectSize(this)" 
              data-label=product.size
              ) #{product.size}
        .pd-divider
        // Quantity & actions
        .pd-qty-row
          .pd-qty
            button(onclick="changeQty(-1)") −
            span#pdQty 1
            button(onclick="changeQty(1)" ) +
          button.btn.btn-gold.btn-add-cart(product-id = product._id)
            svg(
              stroke-width="2" 
              stroke="currentColor" 
              fill="none" 
              viewBox="0 0 24 24" 
              height="18" 
              width="18"
              )
              path(d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z")
              line(
                y2="6" 
                x2="21" 
                y1="6" 
                x1="3"
                )
              path(d="M16 10a4 4 0 0 1-8 0")
            | Thêm vào giỏ hàng
        a.btn.btn-outline-dark.btn-add-cart(
          product-id = product._id
          style="justify-content:center;padding:14px 28px;font-size:.95rem;" 
          href="/cart"
          ) Mua ngay →
        .pd-divider
        // Meta info
        .pd-meta
          .pd-meta-row
            svg(
              stroke-width="2" 
              stroke="currentColor" 
              fill="none" 
              viewBox="0 0 24 24" 
              height="18" 
              width="18"
              )
              rect(
                height="13" 
                width="15" 
                y="3" 
                x="1"
                )
              polygon(points="16 8 20 8 23 11 23 16 16 16 16 8")
              circle(
                r="2.5" 
                cy="18.5" 
                cx="5.5"
                )
              circle(
                r="2.5" 
                cy="18.5" 
                cx="18.5"
                )
            span
              | Giao hàng
              strong(style = "color :white")  2 – 5 ngày
              | · Miễn phí với đơn trên 5 triệu
          .pd-meta-row
            svg(
              stroke-width="2" 
              stroke="currentColor" 
              fill="none" 
              viewBox="0 0 24 24" 
              height="18" 
              width="18"
              )
              path(d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4")
              polyline(points="17 8 12 3 7 8")
              line(
                y2="15" 
                x2="12" 
                y1="3" 
                x1="12"
                )
            span(style = "color :white")
              | Đổi trả miễn phí trong
              strong  30 ngày
          .pd-meta-row
            svg(
              stroke-width="2" 
              stroke="currentColor" 
              fill="none" 
              viewBox="0 0 24 24" 
              height="18" 
              width="18"
              )
              path(d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z")
            span
              | Bảo hành chính hãng
              strong(style = "color :white")  12 tháng
          .pd-meta-row
            svg(
              stroke-width="2" 
              stroke="currentColor" 
              fill="none" 
              viewBox="0 0 24 24" 
              height="18" 
              width="18"
              )
              rect(
                ry="2" 
                rx="2" 
                height="11" 
                width="18" 
                y="11" 
                x="3"
                )
              path(d="M7 11V7a5 5 0 0 1 10 0v4")
            span
              | Thanh toán an toàn: 
              strong(style="color:#0068ff") ZaloPay
              | , 
              strong(style="color:#d81f26") VnPay
        // Share
        div(
          style="display:flex;align-items:center;gap:12px;font-size:.82rem;color:var(--text-light);"
          )
          span Chia sẻ:
          a(
            style="color:#1877F2;font-weight:700;" 
            href="#"
            ) Facebook
          a(
            style="color:#E1306C;font-weight:700;" 
            href="#"
            ) Instagram
          a(
            style="color:#25D366;font-weight:700;" 
            href="#"
            ) Zalo
  // Tabs: Description / Specs / Reviews
  section.container.pd-tabs
    .tab-nav
      button.tab-nav-btn.active(onclick="switchTab('desc', this)") Mô tả sản phẩm
      button.tab-nav-btn(onclick="switchTab('specs', this)") Thông số kỹ thuật
      button.tab-nav-btn(onclick="switchTab('reviews', this)") Đánh giá (128)
    // Description
    #tab-desc.tab-pane.active
      div(style="max-width:800px;font-size:.95rem;color:var(--text-mid);line-height:1.9;")
        h3(style="font-size:1.1rem;font-weight:800;color:var(--white);margin-bottom:12px;") #{product.name}
        p
          | #{product.description}
        br
        h4(style="font-weight:700;color:var(--accent);margin-bottom:8px;") ✦ Điểm nổi bật
          ul(style="list-style:none;padding:0;display:flex;flex-direction:column;gap:8px;")
            li → Thiết kế hiện đại sang trọng — phù hợp phòng khách, phòng ngủ và không gian decor cao cấp
            li → Thân đèn hợp kim sơn tĩnh điện cao cấp — chống oxy hóa, bền đẹp theo thời gian
            li → Chao đèn acrylic/kính cao cấp — ánh sáng dịu mắt, tăng tính thẩm mỹ cho không gian
            li → Sử dụng chip LED tiết kiệm điện — tuổi thọ cao, ánh sáng ổn định
            li → Chỉ số hoàn màu CRI cao — tái hiện màu sắc vật thể chân thực và tự nhiên
            li → Nhiều chế độ ánh sáng linh hoạt — dễ dàng phù hợp với từng nhu cầu sử dụng
    // Specs
    #tab-specs.tab-pane
      table.spec-table
        tbody
          tr
            td Kích thước
            td #{product.size}
          tr
            td Chất liệu bặt
            td #{product.material}
          tr
            td Chỉ số màu
            td #{product.colorIndex}
          tr
            td Công Suất
            td #{product.power}
          tr
            td Nhiệt độ màu
            td 2700K - 6500K
          tr
            td Xuất xứ
            td #{product.made}
          tr
            td Bảo hành
            td 12 tháng
          tr
            td Giao hàng
            td 2–5 ngày làm việc
    // Reviews
    #tab-reviews.tab-pane
      // Summary
      div(
        style="display:grid;grid-template-columns:160px 1fr;gap:32px;align-items:center;margin-bottom:32px;padding:24px;background:var(--off-white);border-radius:var(--radius-lg);"
        )
        div(style="text-align:center;")
          div(style="font-size:3.5rem;font-weight:900;color:var(--white);line-height:1;") 4.9
          div(style="color:#f5a623;font-size:1.2rem;margin:6px 0;") ★★★★★
          div(style="font-size:.8rem;color:var(--text-light);") 128 đánh giá
        div(style="display:flex;flex-direction:column;gap:6px;")
          div(style="display:flex;align-items:center;gap:10px;font-size:.82rem;")
            span(style="width:20px;text-align:right;") 5★
            div(style="flex:1;height:8px;background:var(--border);border-radius:4px;overflow:hidden;")
              div(style="width:90%;height:100%;background:#f5a623;border-radius:4px;")
            span(style="color:var(--text-light);") 112
          div(style="display:flex;align-items:center;gap:10px;font-size:.82rem;")
            span(style="width:20px;text-align:right;") 4★
            div(style="flex:1;height:8px;background:var(--border);border-radius:4px;overflow:hidden;")
              div(style="width:10%;height:100%;background:#f5a623;border-radius:4px;")
            span(style="color:var(--text-light);") 12
          div(style="display:flex;align-items:center;gap:10px;font-size:.82rem;")
            span(style="width:20px;text-align:right;") 3★
            div(style="flex:1;height:8px;background:var(--border);border-radius:4px;overflow:hidden;")
              div(style="width:3%;height:100%;background:#f5a623;border-radius:4px;")
            span(style="color:var(--text-light);") 4
      #reviewList
        .review-item
          .review-author
            img.review-avatar(
              alt="Khách hàng" 
              src="../assets/images/thanh.jpg"
              )
            div
              .review-name(style ="color :var(--white)") Đỗ Văn Thành
              .review-date(style ="color :var(--text-light)") 5/8/2026
          .review-stars ★★★★★
          p.review-text
            | Đèn đẹp hơn hình rất nhiều! Chất liệu da mềm, màu vàng bò rất sang trọng. Đội ngũ giao hàng chuyên nghiệp, lắp đặt nhanh gọn. Rất hài lòng với lựa chọn này!
        .review-item
          .review-author
            img.review-avatar(
              alt="Khách hàng" 
              src="../assets/images/manhquynhdz.png"
              )
            div
              .review-name(style ="color :var(--white)") Trần Minh Tuấn
              .review-date(style ="color :var(--text-light)") 28/03/2024
          .review-stars ★★★★★
          p.review-text
            | Mua lần thứ 2 rồi, chất lượng vẫn rất tốt như lần đầu. Khung gỗ chắc, đệm ngồi thoải mái. Phòng khách nhà mình nhờ cái đèn này mà trông sang hẳn lên.
        .review-item
          .review-author
            img.review-avatar(
              alt="Khách hàng" 
              src="../assets/images/nghia.png"
              )
            div
              .review-name(style ="color :var(--white)") Lê Thị Hương
              .review-date(style ="color :var(--text-light)") 15/03/2024
          .review-stars ★★★★☆
          p.review-text
            | Đèn rất đẹp và sang trọng. Về chất lượng thì đúng với mô tả. Chỉ tiếc là giao hàng chậm hơn dự kiến 1 ngày, nhưng nhìn chung vẫn OK. Sẽ giới thiệu cho bạn bè.
      // Write review
      div(
        style="margin-top:32px;padding:28px;border:2px solid var(--border);border-radius:var(--radius-xl);"
        )
        h4(style="font-size:1rem;font-weight:800;margin-bottom:20px;color:var(--white);") Viết đánh giá của bạn
        form(style="display:grid;gap:16px;")
          div(style="display:flex;gap:4px;font-size:1.5rem;cursor:pointer;color:#f5a623;")
            span ★
            span ★
            span ★
            span ★
            span ★
          div(style="display:grid;grid-template-columns:1fr 1fr;gap:16px;")
            .form-group(style="margin:0;")
              label Họ tên
              input.form-control(
                placeholder="Nguyễn Văn A" 
                type="text"
                )
            .form-group(style="margin:0;")
              label Email
              input.form-control(
                placeholder="example@email.com" 
                type="email"
                )
          .form-group(style="margin:0;")
            label Đánh giá của bạn *
            textarea.form-control(
              style="resize:vertical;" 
              placeholder="Chia sẻ trải nghiệm của bạn về sản phẩm này..." 
              rows="4"
              )
          button.btn.btn-gold(style="justify-content:center;padding:14px;") Gửi đánh giá
  // Related products
  section.section(style="background:var(--off-white);")
    .container
      .section-head
        div
          p.section-eyebrow Gợi ý
          h2.section-title Sản phẩm liên quan
        a.btn.btn-outline-dark.btn-sm(href="/products") Xem tất cả
      .products-grid
        each item in productList
          article.prod-card
            a.prod-img-wrap(href=`/products/${item.slug}`)
              .prod-image
                img(
                  alt=""
                  src=item.avatar
                  )
                span.prod-badge - #{Math.floor(((Number(item.priceOLD) - Number(item.priceNEW)) / Number(item.priceOLD)) * 100)}%
              .prod-overlay
                button.quick-add Thêm giỏ hàng
            .prod-body
              span(
                style="font-size:.72rem;font-weight:700;color:var(--accent-dark);text-transform:uppercase;"
                ) #{item.category[0].name}
              h3.prod-name
                a(href=`/products/${item.slug}`)
                  | #{item.name}
              .prod-price
                span.price-new #{Number(item.priceNEW).toLocaleString('vi-VN')} ₫
                span.price-old #{Number(item.priceOLD).toLocaleString('vi-VN')} ₫

              .prod-stars ★★★★★