extends ../layouts/default.pug

block content
  .container(style="padding-top:20px;")
    nav.breadcrumb(style="background:none;padding:0;")
      span Ghế Sofa Văng Da Hàn Quốc
  // Product detail
  section.container
    .pd-wrap
      // LEFT: Gallery
      .pd-gallery
        #pdMainImg.pd-main-img
          img#pdMainImgEl(
            alt="Ghế Sofa Văng Da Hàn Quốc" 
            src="https://i.pinimg.com/736x/24/4c/51/244c51c0f493b13b5b9f9e8dcb8ab241.jpg"
            )
        #pdThumbs.pd-thumbs
          .pd-thumb.active(
            data-src="https://i.pinimg.com/736x/24/4c/51/244c51c0f493b13b5b9f9e8dcb8ab241.jpg"
            )
            img(
              alt="" 
              src="https://i.pinimg.com/736x/24/4c/51/244c51c0f493b13b5b9f9e8dcb8ab241.jpg"
              )
          .pd-thumb(
            data-src="https://cdn3729.cdn-template-4s.com/thumbs/san-pham/sf618011-123-1666x1250_1_thumb_350.jpg"
            )
            img(
              alt="" 
              src="https://cdn3729.cdn-template-4s.com/thumbs/san-pham/sf618011-123-1666x1250_1_thumb_350.jpg"
              )
          .pd-thumb(
            data-src="https://cdn3729.cdn-template-4s.com/thumbs/san-pham/sf005-123-1666x1250_thumb_350.jpg"
            )
            img(
              alt="" 
              src="https://cdn3729.cdn-template-4s.com/thumbs/san-pham/sf005-123-1666x1250_thumb_350.jpg"
              )
          .pd-thumb(data-src="https://cdn3729.cdn-template-4s.com/thumbs/san-pham/hns142-2_thumb_350.jpg")
            img(
              alt="" 
              src="https://cdn3729.cdn-template-4s.com/thumbs/san-pham/hns142-2_thumb_350.jpg"
              )
      // RIGHT: Info
      .pd-info
        div
          p.pd-category Cổ Điển
          h1.pd-name Đèn Trang Trí Hiện Đại Thanh Lịch Phong Cách Hàn Quốc
        .pd-stars
          span.stars ★★★★★
          span 4.9 (128 đánh giá)
          span(style="color:#2a9d5c;font-weight:600;") · Còn hàng
        .pd-price-wrap
          span.pd-price-new 34.000.000 ₫
          span.pd-price-old 36.000.000 ₫
          span.pd-save –6%
        p(style="font-size:.9rem;color:var(--text-mid);line-height:1.8;")
          |Đèn trang trí được thiết kế theo phong cách hiện đại tinh tế, lấy cảm hứng từ xu hướng nội thất Hàn Quốc, mang lại vẻ đẹp sang trọng và ấm áp cho không gian sống. Sử dụng chất liệu cao cấp với thân đèn hợp kim chắc chắn, chao đèn thiết kế tỉ mỉ giúp ánh sáng tỏa ra dịu nhẹ, bền bỉ theo thời gian. Sản phẩm phù hợp cho phòng khách, phòng ngủ, quán cà phê hoặc không gian decor hiện đại, tạo điểm nhấn thẩm mỹ và nâng tầm không gian sống.
        .pd-divider
        // Color selection
        div
          p.pd-label
            | Màu sắc:
            strong#colorLabel(style="color:var(--primary);font-weight:800;") Vàng bò
          .pd-colors
            button.pd-color-btn.active(
              onclick="selectColor(this)" 
              data-label="Vàng bò" 
              title="Vàng bò" 
              style="background:#c8a063;"
              )
            button.pd-color-btn(
              onclick="selectColor(this)" 
              data-label="Nâu đậm" 
              title="Nâu đậm" 
              style="background:#4a3728;"
              )
            button.pd-color-btn(
              onclick="selectColor(this)" 
              data-label="Kem" 
              title="Kem" 
              style="background:#e8ddd0;"
              )
            button.pd-color-btn(
              onclick="selectColor(this)" 
              data-label="Xanh rêu" 
              title="Xanh rêu" 
              style="background:#2E3D36;"
              )
            button.pd-color-btn(
              onclick="selectColor(this)" 
              data-label="Xám" 
              title="Xám" 
              style="background:#8c8c8c;"
              )
        // Size selection
        div
          p.pd-label
            | Kích thước
          .pd-sizes
            button.pd-size-btn.active(
              onclick="selectSize(this)" 
              data-label="2 chỗ ngồi"
              ) 2 chỗ (160cm)
            button.pd-size-btn(
              onclick="selectSize(this)" 
              data-label="3 chỗ ngồi"
              ) 3 chỗ (220cm)
        .pd-divider
        // Quantity & actions
        .pd-qty-row
          .pd-qty
            button(onclick="changeQty(-1)") −
            span#pdQty 1
            button(onclick="changeQty(1)") +
          a.btn.btn-gold.btn-add-cart(href="cart.html")
            svg(
              stroke-width="2" 
              stroke="currentColor" 
              fill="none" 
              viewBox="0 0 24 24" 
              height="18" 
              width="18"
              )
              path(d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z")
              line(
                y2="6" 
                x2="21" 
                y1="6" 
                x1="3"
                )
              path(d="M16 10a4 4 0 0 1-8 0")
            | Thêm vào giỏ hàng
          button.btn-wishlist(title="Yêu thích")
            svg(
              stroke-width="2" 
              stroke="currentColor" 
              fill="none" 
              viewBox="0 0 24 24" 
              height="20" 
              width="20"
              )
              path(
                d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"
                )
        a.btn.btn-outline-dark(
          style="justify-content:center;padding:14px 28px;font-size:.95rem;" 
          href="checkout.html"
          ) Mua ngay →
        .pd-divider
        // Meta info
        .pd-meta
          .pd-meta-row
            svg(
              stroke-width="2" 
              stroke="currentColor" 
              fill="none" 
              viewBox="0 0 24 24" 
              height="18" 
              width="18"
              )
              rect(
                height="13" 
                width="15" 
                y="3" 
                x="1"
                )
              polygon(points="16 8 20 8 23 11 23 16 16 16 16 8")
              circle(
                r="2.5" 
                cy="18.5" 
                cx="5.5"
                )
              circle(
                r="2.5" 
                cy="18.5" 
                cx="18.5"
                )
            span
              | Giao hàng
              strong  2 – 5 ngày
              | · Miễn phí với đơn trên 5 triệu
          .pd-meta-row
            svg(
              stroke-width="2" 
              stroke="currentColor" 
              fill="none" 
              viewBox="0 0 24 24" 
              height="18" 
              width="18"
              )
              path(d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4")
              polyline(points="17 8 12 3 7 8")
              line(
                y2="15" 
                x2="12" 
                y1="3" 
                x1="12"
                )
            span
              | Đổi trả miễn phí trong
              strong  30 ngày
          .pd-meta-row
            svg(
              stroke-width="2" 
              stroke="currentColor" 
              fill="none" 
              viewBox="0 0 24 24" 
              height="18" 
              width="18"
              )
              path(d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z")
            span
              | Bảo hành chính hãng
              strong  12 tháng
          .pd-meta-row
            svg(
              stroke-width="2" 
              stroke="currentColor" 
              fill="none" 
              viewBox="0 0 24 24" 
              height="18" 
              width="18"
              )
              rect(
                ry="2" 
                rx="2" 
                height="11" 
                width="18" 
                y="11" 
                x="3"
                )
              path(d="M7 11V7a5 5 0 0 1 10 0v4")
            span
              | Thanh toán an toàn: 
              strong(style="color:#0068ff") ZaloPay
              | , 
              strong(style="color:#d81f26") VnPay
        // Share
        div(
          style="display:flex;align-items:center;gap:12px;font-size:.82rem;color:var(--text-light);"
          )
          span Chia sẻ:
          a(
            style="color:#1877F2;font-weight:700;" 
            href="#"
            ) Facebook
          a(
            style="color:#E1306C;font-weight:700;" 
            href="#"
            ) Instagram
          a(
            style="color:#25D366;font-weight:700;" 
            href="#"
            ) Zalo
  // Tabs: Description / Specs / Reviews
  section.container.pd-tabs
    .tab-nav
      button.tab-nav-btn.active(onclick="switchTab('desc', this)") Mô tả sản phẩm
      button.tab-nav-btn(onclick="switchTab('specs', this)") Thông số kỹ thuật
      button.tab-nav-btn(onclick="switchTab('reviews', this)") Đánh giá (128)
    // Description
    #tab-desc.tab-pane.active
      div(style="max-width:800px;font-size:.95rem;color:var(--text-mid);line-height:1.9;")
        h3(style="font-size:1.1rem;font-weight:800;color:var(--primary);margin-bottom:12px;") Ghế Sofa Văng Da Hàn Quốc – Đỉnh Cao Của Phong Cách Hiện Đại
        p
          | Ghế sofa văng từ bộ sưu tập
          strong Premium Collection
          | của OH!Decor — sự kết hợp hoàn hảo giữa vẻ đẹp thẩm mỹ và công năng sử dụng thực tiễn. Với phần đệm rộng và mềm mại, chiếc sofa này không chỉ là chỗ ngồi mà còn là điểm nhấn trang trí hoàn hảo cho không gian phòng khách của bạn.
        br
        h4(style="font-weight:700;color:var(--primary);margin-bottom:8px;") ✦ Điểm nổi bật
        ul(style="list-style:none;padding:0;display:flex;flex-direction:column;gap:8px;")
          li → Chất liệu da bò Hàn Quốc nhập khẩu, mềm mại tự nhiên, bền màu theo thời gian
          li → Khung gỗ sồi Mỹ sấy kiệt chuẩn kỹ thuật — không mọt, không cong vênh
          li → Đệm mút D40 cao cấp mật độ cao, giữ form lâu, đàn hồi tốt
          li → Lò xo zigzag ở lưng ghế — tạo cảm giác ngồi thoải mái, chắc chắn
          li → Chân sofa kim loại mạ đồng cao cấp — chịu lực tốt, không gỉ sét
          li → Thiết kế modular linh hoạt — phù hợp nhiều không gian khác nhau
    // Specs
    #tab-specs.tab-pane
      table.spec-table
        tbody
          tr
            td Kích thước
            td D300 × H500 mm
          tr
            td Chất liệu bặt
            td Khung gỗ sồi Mỹ (oak)
            td Chỉ số màu
            td > 80
          tr
            td Công Suất
            td 12W
          tr
            td Nhiệt độ màu
            td 2700K - 6500K
          tr
            td Xuất xứ
            td Việt Nam (nguyên liệu nhập khẩu)
          tr
            td Bảo hành
            td 12 tháng
          tr
            td Giao hàng
            td 2–5 ngày làm việc
    // Reviews
    #tab-reviews.tab-pane
      // Summary
      div(
        style="display:grid;grid-template-columns:160px 1fr;gap:32px;align-items:center;margin-bottom:32px;padding:24px;background:var(--off-white);border-radius:var(--radius-lg);"
        )
        div(style="text-align:center;")
          div(style="font-size:3.5rem;font-weight:900;color:var(--primary);line-height:1;") 4.9
          div(style="color:#f5a623;font-size:1.2rem;margin:6px 0;") ★★★★★
          div(style="font-size:.8rem;color:var(--text-light);") 128 đánh giá
        div(style="display:flex;flex-direction:column;gap:6px;")
          div(style="display:flex;align-items:center;gap:10px;font-size:.82rem;")
            span(style="width:20px;text-align:right;") 5★
            div(style="flex:1;height:8px;background:var(--border);border-radius:4px;overflow:hidden;")
              div(style="width:90%;height:100%;background:#f5a623;border-radius:4px;")
            span(style="color:var(--text-light);") 112
          div(style="display:flex;align-items:center;gap:10px;font-size:.82rem;")
            span(style="width:20px;text-align:right;") 4★
            div(style="flex:1;height:8px;background:var(--border);border-radius:4px;overflow:hidden;")
              div(style="width:10%;height:100%;background:#f5a623;border-radius:4px;")
            span(style="color:var(--text-light);") 12
          div(style="display:flex;align-items:center;gap:10px;font-size:.82rem;")
            span(style="width:20px;text-align:right;") 3★
            div(style="flex:1;height:8px;background:var(--border);border-radius:4px;overflow:hidden;")
              div(style="width:3%;height:100%;background:#f5a623;border-radius:4px;")
            span(style="color:var(--text-light);") 4
      #reviewList
        .review-item
          .review-author
            img.review-avatar(
              alt="Khách hàng" 
              src=""
              )
            div
              .review-name Nguyễn Thị Mai
              .review-date 12/04/2024
          .review-stars ★★★★★
          p.review-text
            | Sofa đẹp hơn hình rất nhiều! Chất liệu da mềm, màu vàng bò rất sang trọng. Đội ngũ giao hàng chuyên nghiệp, lắp đặt nhanh gọn. Rất hài lòng với lựa chọn này!
        .review-item
          .review-author
            img.review-avatar(
              alt="Khách hàng" 
              src="../assets/images/manhquynhdz.png"
              )
            div
              .review-name Trần Minh Tuấn
              .review-date 28/03/2024
          .review-stars ★★★★★
          p.review-text
            | Mua lần thứ 2 rồi, chất lượng vẫn rất tốt như lần đầu. Khung gỗ chắc, đệm ngồi thoải mái. Phòng khách nhà mình nhờ cái sofa này mà trông sang hẳn lên.
        .review-item
          .review-author
            img.review-avatar(
              alt="Khách hàng" 
              src="/assets/images/manhquynhdz.png"
              )
            div
              .review-name Lê Thị Hương
              .review-date 15/03/2024
          .review-stars ★★★★☆
          p.review-text
            | Sofa rất đẹp và sang trọng. Về chất lượng thì đúng với mô tả. Chỉ tiếc là giao hàng chậm hơn dự kiến 1 ngày, nhưng nhìn chung vẫn OK. Sẽ giới thiệu cho bạn bè.
      // Write review
      div(
        style="margin-top:32px;padding:28px;border:2px solid var(--border);border-radius:var(--radius-xl);"
        )
        h4(style="font-size:1rem;font-weight:800;margin-bottom:20px;color:var(--primary);") Viết đánh giá của bạn
        form(style="display:grid;gap:16px;")
          div(style="display:flex;gap:4px;font-size:1.5rem;cursor:pointer;color:#f5a623;")
            span ★
            span ★
            span ★
            span ★
            span ★
          div(style="display:grid;grid-template-columns:1fr 1fr;gap:16px;")
            .form-group(style="margin:0;")
              label Họ tên
              input.form-control(
                placeholder="Nguyễn Văn A" 
                type="text"
                )
            .form-group(style="margin:0;")
              label Email
              input.form-control(
                placeholder="example@email.com" 
                type="email"
                )
          .form-group(style="margin:0;")
            label Đánh giá của bạn *
            textarea.form-control(
              style="resize:vertical;" 
              placeholder="Chia sẻ trải nghiệm của bạn về sản phẩm này..." 
              rows="4"
              )
          button.btn.btn-gold(style="justify-content:center;padding:14px;") Gửi đánh giá
  // Related products
  section.section(style="background:var(--off-white);")
    .container
      .section-head
        div
          p.section-eyebrow Gợi ý
          h2.section-title Sản phẩm liên quan
        a.btn.btn-outline-dark.btn-sm(href="products.html") Xem tất cả
      .products-grid
        article.prod-card
          a.prod-img-wrap(href="product-detail.html")
            img(
              alt="Sofa Mỹ" 
              src="https://cdn3729.cdn-template-4s.com/thumbs/san-pham/sf618011-123-1666x1250_1_thumb_350.jpg"
              )
            span.prod-badge -22%
            .prod-overlay
              button.quick-add Thêm giỏ hàng
          .prod-body
            span(
              style="font-size:.72rem;font-weight:700;color:var(--accent-dark);text-transform:uppercase;"
              ) SOFA
            h3.prod-name
              a(href="product-detail.html") Sofa Phong Cách Mỹ SF007-123
            .prod-price
              span.price-old 45.000.000 ₫
              span.price-new 35.000.000 ₫
            .prod-stars ★★★★★
        article.prod-card
          a.prod-img-wrap(href="product-detail.html")
            img(
              alt="Sofa" 
              src="https://cdn3729.cdn-template-4s.com/thumbs/san-pham/sf005-123-1666x1250_thumb_350.jpg"
              )
            span.prod-badge -7%
            .prod-overlay
              button.quick-add Thêm giỏ hàng
          .prod-body
            span(
              style="font-size:.72rem;font-weight:700;color:var(--accent-dark);text-transform:uppercase;"
              ) SOFA
            h3.prod-name
              a(href="product-detail.html") Sofa Phong Cách Mỹ SF618015-123
            .prod-price
              span.price-old 6.000.000 ₫
              span.price-new 5.600.000 ₫
            .prod-stars ★★★★☆
        article.prod-card
          a.prod-img-wrap(href="product-detail.html")
            img(
              alt="Sofa góc" 
              src="https://cdn3729.cdn-template-4s.com/thumbs/san-pham/hns142-2_thumb_350.jpg"
              )
            span.prod-badge -20%
            .prod-overlay
              button.quick-add Thêm giỏ hàng
          .prod-body
            span(
              style="font-size:.72rem;font-weight:700;color:var(--accent-dark);text-transform:uppercase;"
              ) SOFA
            h3.prod-name
              a(href="product-detail.html") Sofa góc L HNS142 – Thiết kế hiện đại
            .prod-price
              span.price-old 3.750.000 ₫
              span.price-new 3.000.000 ₫
            .prod-stars ★★★★★
        article.prod-card
          a.prod-img-wrap(href="product-detail.html")
            img(
              alt="Ghế" 
              src="https://cdn3729.cdn-template-4s.com/thumbs/danh-muc/download_1_thumb_350.webp"
              )
            .prod-overlay
              button.quick-add Thêm giỏ hàng
          .prod-body
            span(
              style="font-size:.72rem;font-weight:700;color:var(--accent-dark);text-transform:uppercase;"
              ) GHẾ
            h3.prod-name
              a(href="product-detail.html") Ghế Accent hiện đại tối giản
            .prod-price
              span.price-new 4.500.000 ₫
            .prod-stars ★★★★☆