extends ../layouts/default.pug

block content
  .container(style="padding-top:20px;")
    nav.breadcrumb(style="background:none;padding:0;")

  // Product detail
  section.container
    .pd-wrap
      // LEFT: 
      .pd-gallery
        #pdMainImg.pd-main-img
          img#pdMainImgEl(
            alt=""
            src=product.avatar
            )
        #pdThumbs.pd-thumbs
          .pd-thumb.active(data-src=product.avatar)
            img(src=product.avatar)
          if product.images
            each item in product.images
              .pd-thumb(data-src=item)
                img(src=item)
         
      // RIGHT: Info
      .pd-info
        div
          p.pd-category #{product.category ? product.category.map(c => c.name).join(", ") : ""}
          h1.pd-name #{product.name}
        .pd-stars
          if (ratingAvg >= 4.5)
            span(style="color:var(--accent); font-weight: 600;") ★★★★★
          else if (ratingAvg >= 4)
            span(style="color:var(--accent); font-weight: 600;") ★★★★☆
          else if (ratingAvg >= 3)
            span(style="color:var(--accent); font-weight: 600;") ★★★☆☆
          else if (ratingAvg >= 2)
            span(style="color:var(--accent); font-weight: 600;") ★★☆☆☆
          else
            span(style="color:var(--accent); font-weight: 600;") ★☆☆☆☆
          span #{ratingAvg ? ratingAvg.toFixed(1) : 0} (#{listReview.length} đánh giá)
          span(style="color:#2a9d5c;font-weight:600;") · Còn hàng
        .pd-price-wrap
          span.pd-price-new #{Number(product.priceNEW).toLocaleString('vi-VN')} ₫
          span.pd-price-old #{Number(product.priceOLD).toLocaleString('vi-VN')} ₫
          span.pd-save - #{Number(product.priceOLD) > 0 ? Math.floor(((Number(product.priceOLD) - Number(product.priceNEW)) / Number(product.priceOLD)) * 100) : 0}%
        p(style="font-size:.9rem;color:var(--text-mid);line-height:1.8;")
          | #{product.description}
        .pd-divider
        // Color selection
        div
          p.pd-label
            | Màu sắc : 
            strong#colorLabel(style="color:yellow;font-weight:800;") #{product.colorIndex}

        // Size selection
        div
          p.pd-label
            | Kích thước
          .pd-sizes
            button.pd-size-btn.active(
              onclick="selectSize(this)" 
              data-label=product.size
              ) #{product.size}
        .pd-divider
        // Quantity & actions
        .pd-qty-row
          .pd-qty
            button(onclick="changeQty(-1)") −
            span#pdQty 1
            button(onclick="changeQty(1)" ) +
          button.btn.btn-gold.btn-add-cart(product-id = product._id)
            svg(
              stroke-width="2" 
              stroke="currentColor" 
              fill="none" 
              viewBox="0 0 24 24" 
              height="18" 
              width="18"
              )
              path(d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z")
              line(
                y2="6" 
                x2="21" 
                y1="6" 
                x1="3"
                )
              path(d="M16 10a4 4 0 0 1-8 0")
            | Thêm vào giỏ hàng
        a.btn.btn-outline-dark.btn-add-cart(
          product-id = product._id
          style="justify-content:center;padding:14px 28px;font-size:.95rem;" 
          href="/cart"
          ) Mua ngay →
        .pd-divider
        // Meta info
        .pd-meta
          .pd-meta-row
            svg(
              stroke-width="2" 
              stroke="currentColor" 
              fill="none" 
              viewBox="0 0 24 24" 
              height="18" 
              width="18"
              )
              rect(
                height="13" 
                width="15" 
                y="3" 
                x="1"
                )
              polygon(points="16 8 20 8 23 11 23 16 16 16 16 8")
              circle(
                r="2.5" 
                cy="18.5" 
                cx="5.5"
                )
              circle(
                r="2.5" 
                cy="18.5" 
                cx="18.5"
                )
            span
              | Giao hàng
              strong(style = "color :white")  2 – 5 ngày
              | · Miễn phí với đơn trên 5 triệu
          .pd-meta-row
            svg(
              stroke-width="2" 
              stroke="currentColor" 
              fill="none" 
              viewBox="0 0 24 24" 
              height="18" 
              width="18"
              )
              path(d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4")
              polyline(points="17 8 12 3 7 8")
              line(
                y2="15" 
                x2="12" 
                y1="3" 
                x1="12"
                )
            span(style = "color :white")
              | Đổi trả miễn phí trong
              strong  30 ngày
          .pd-meta-row
            svg(
              stroke-width="2" 
              stroke="currentColor" 
              fill="none" 
              viewBox="0 0 24 24" 
              height="18" 
              width="18"
              )
              path(d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z")
            span
              | Bảo hành chính hãng
              strong(style = "color :white")  12 tháng
          .pd-meta-row
            svg(
              stroke-width="2" 
              stroke="currentColor" 
              fill="none" 
              viewBox="0 0 24 24" 
              height="18" 
              width="18"
              )
              rect(
                ry="2" 
                rx="2" 
                height="11" 
                width="18" 
                y="11" 
                x="3"
                )
              path(d="M7 11V7a5 5 0 0 1 10 0v4")
            span
              | Thanh toán an toàn: 
              strong(style="color:#0068ff") ZaloPay
              | , 
              strong(style="color:#d81f26") VnPay
        // Share
        div(
          style="display:flex;align-items:center;gap:12px;font-size:.82rem;color:var(--text-light);"
          )
          span Chia sẻ:
          a(
            style="color:#1877F2;font-weight:700;" 
            href="#"
            ) Facebook
          a(
            style="color:#E1306C;font-weight:700;" 
            href="#"
            ) Instagram
          a(
            style="color:#25D366;font-weight:700;" 
            href="#"
            ) Zalo
  // Tabs: Description / Specs / Reviews
  section.container.pd-tabs
    .tab-nav
      button.tab-nav-btn.active(onclick="switchTab('desc', this)") Mô tả sản phẩm
      button.tab-nav-btn(onclick="switchTab('specs', this)") Thông số kỹ thuật
      button.tab-nav-btn(onclick="switchTab('reviews', this)") Đánh giá (#{listReview.length})
    // Description
    #tab-desc.tab-pane.active
      div(style="max-width:800px;font-size:.95rem;color:var(--text-mid);line-height:1.9;")
        h3(style="font-size:1.1rem;font-weight:800;color:var(--white);margin-bottom:12px;") #{product.name}
        p
          | #{product.description}
        br
        h4(style="font-weight:700;color:var(--accent);margin-bottom:8px;") ✦ Điểm nổi bật
          ul(style="list-style:none;padding:0;display:flex;flex-direction:column;gap:8px;")
            li → Thiết kế hiện đại sang trọng — phù hợp phòng khách, phòng ngủ và không gian decor cao cấp
            li → Thân đèn hợp kim sơn tĩnh điện cao cấp — chống oxy hóa, bền đẹp theo thời gian
            li → Chao đèn acrylic/kính cao cấp — ánh sáng dịu mắt, tăng tính thẩm mỹ cho không gian
            li → Sử dụng chip LED tiết kiệm điện — tuổi thọ cao, ánh sáng ổn định
            li → Chỉ số hoàn màu CRI cao — tái hiện màu sắc vật thể chân thực và tự nhiên
            li → Nhiều chế độ ánh sáng linh hoạt — dễ dàng phù hợp với từng nhu cầu sử dụng
    // Specs
    #tab-specs.tab-pane
      table.spec-table
        tbody
          tr
            td Kích thước
            td #{product.size}
          tr
            td Chất liệu bặt
            td #{product.material}
          tr
            td Chỉ số màu
            td #{product.colorIndex}
          tr
            td Công Suất
            td #{product.power}
          tr
            td Nhiệt độ màu
            td 2700K - 6500K
          tr
            td Xuất xứ
            td #{product.made}
          tr
            td Bảo hành
            td 12 tháng
          tr
            td Giao hàng
            td 2–5 ngày làm việc
    // Reviews
    #tab-reviews.tab-pane
      // Summary
      div(
        style="display:grid;grid-template-columns:160px 1fr;gap:32px;align-items:center;margin-bottom:32px;padding:24px;background:var(--off-white);border-radius:var(--radius-lg);"
        )
        div(style="text-align:center;")
          div(style="font-size:3.5rem;font-weight:900;color:var(--white);line-height:1;") #{ratingAvg ? ratingAvg.toFixed(1) : 0}
          div(style="color:#f5a623;font-size:1.2rem;margin:6px 0;")
            if(ratingAvg>=4.5)
              span ★★★★★
            else if(ratingAvg>=4)
              span ★★★★☆
            else if(ratingAvg>=3)
              span ★★★☆☆
            else if(ratingAvg>=2)
              span ★★☆☆☆
            else
              span ★☆☆☆☆
          div(style="font-size:.8rem;color:var(--text-light);") #{listReview.length} đánh giá
        div(style="display:flex;flex-direction:column;gap:6px;")
          - const starRatings = [5, 4, 3, 2, 1]
          - const ratingCounts = {5: 0, 4: 0, 3: 0, 2: 0, 1: 0}
          - listReview.forEach(item =>  { if(ratingCounts[item.rating] !== undefined) ratingCounts[item.rating]++ })
          - const totalReviews = listReview.length
          each star in starRatings
            - const count = ratingCounts[star]
            - const percent = totalReviews > 0 ? (count / totalReviews * 100) : 0
            div(style="display:flex;align-items:center;gap:10px;font-size:.82rem;")
              span(style="width:20px;text-align:right;") #{star}★
              div(style="flex:1;height:8px;background:var(--border);border-radius:4px;overflow:hidden;")
                div(style=`width:${percent}%;height:100%;background:#f5a623;border-radius:4px; transition: width 0.3s ease;`)
              span(style="color:var(--text-light);") #{count}
      #reviewList
         each item in listReview
           .review-item
       
            .review-author
              img.review-avatar(
                alt="Khách hàng" 
                src=item.userId.avatar || "" 
                )
              div
                .review-name(style ="color :var(--white)") #{item.userId.firstname + " " +item.userId.lastname}
                .review-date(style ="color :var(--text-light)") #{item.createdAtFormat}
            .review-stars 
              if item.rating == 1
                span(style="color:var(--yellow)") ★
              if item.rating == 2
                span(style="color:var(--yellow)") ★★
              if item.rating == 3
                span(style="color:var(--yellow)") ★★★
              if item.rating == 4
                span(style="color:var(--yellow)") ★★★★
              if item.rating == 5
                span(style="color:var(--yellow)") ★★★★★
            if item.images && item.images.length > 0
              div(
                style="display:flex;flex-direction:row;gap:6px;"
              )
                each image,index in item.images
                  img.review-image(
                    alt="Ảnh review"
                    src=image
                    style = "width:290px;height: 290px;object-fit: cover;"
                  )
            p.review-text
              | #{item.content}
       
      // Write review
      if(user)
        if(order.includes(product._id.toString()))
          div(
            style="margin-top:32px;padding:28px;border:2px solid var(--border);border-radius:var(--radius-xl);"
            )
            h4(style="font-size:1rem;font-weight:800;margin-bottom:20px;color:var(--white);") Viết đánh giá của bạn
            form#review-form(style="display:grid;gap:16px;")
              div.rating(
                style="display:flex;gap:4px;font-size:1.5rem;cursor:pointer;color:#ccc;"
              )
                input(type="hidden" name="rating" id="ratingValue")
                each number in [1,2,3,4,5]
                  span(data-value=number) ★
                
              .form-group(style="display:none")
                input.form-control(
                type="text"
                name="productId"
                id="productId"
                value = product._id
                )
              .form-group(style="display:none")
                input.form-control(
                type="text"
                name="slug"
                id="slug"
                value = product.slug
                )
              .form-group(style="margin:0;")
                label Ảnh sản phẩm 
                  div()
                    input(
                      type="file"
                      id="images"
                      name="images"
                      multiple
                      accept="image/*"
                      filepond-image-multi
                    )
              .form-group(style="margin:0;")
                label Đánh giá của bạn *
                textarea.form-control(
                  style="resize:vertical;" 
                  placeholder="Chia sẻ trải nghiệm của bạn về sản phẩm này..." 
                  rows="4"
                  name = "content"
                  id="content"
                  )
              button.btn.btn-gold(style="justify-content:center;padding:14px;") Gửi đánh giá
        else
          div(
            style="margin-top:32px;padding:24px;background:var(--off-white);border-radius:var(--radius-lg);text-align:center;border:1px dashed var(--border);"
          )
            p(style="color:var(--text-mid);margin:0;") Bạn cần mua sản phẩm này để có thể gửi đánh giá.
      else
        div(
          style="margin-top:32px;padding:24px;background:var(--off-white);border-radius:var(--radius-lg);text-align:center;border:1px dashed var(--border);"
        )
          p(style="color:var(--text-mid);margin:0;")
            | Vui lòng 
            a(href="/login" style="color:var(--gold);font-weight:700;text-decoration:underline;") Đăng nhập
            |  để gửi đánh giá của bạn.
  // Related products
  section.section(style="background:var(--off-white);")
    .container
      .section-head
        div
          p.section-eyebrow Gợi ý
          h2.section-title Sản phẩm liên quan
        a.btn.btn-outline-dark.btn-sm(href="/products") Xem tất cả
      .products-grid
        each item in productList
          article.prod-card
            a.prod-img-wrap(href=`/products/${item.slug}`)
              .prod-image
                img(
                  alt=""
                  src=item.avatar
                  )
                span.prod-badge - #{Math.floor(((Number(item.priceOLD) - Number(item.priceNEW)) / Number(item.priceOLD)) * 100)}%
              .prod-overlay
                button.quick-add Thêm giỏ hàng
            .prod-body
              span(
                style="font-size:.72rem;font-weight:700;color:var(--accent-dark);text-transform:uppercase;"
                ) #{item.category[0].name}
              h3.prod-name
                a(href=`/products/${item.slug}`)
                  | #{item.name}
              .prod-price
                span.price-new #{Number(item.priceNEW).toLocaleString('vi-VN')} ₫
                span.price-old #{Number(item.priceOLD).toLocaleString('vi-VN')} ₫

              .prod-stars ★★★★★