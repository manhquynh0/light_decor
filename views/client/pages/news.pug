extends ../layouts/default.pug

block content
  .page-hero(style="padding:0; margin-bottom: 40px;")
    .hero-image-wrap(style="width: 100%; height: 550px; overflow: hidden;")
      img(src="/assets/images/new.png" alt="ManhQuynh" style="width: 100%; height: 100%; object-fit: cover;")
    .container(style="margin-top: -60px; position: relative; z-index: 2;")
      nav.breadcrumb(style="background: rgba(0,0,0,0.5); display: inline-flex; padding: 10px 20px; border-radius: 8px; backdrop-filter: blur(4px);")
        a(href="/home" style="color: var(--white);") Trang chủ
        span(style="color: var(--text-light); margin: 0 10px;") ›
        span(style="color: var(--accent);") Tin tức & Cảm hứng

  section.section
    .container
      // Category filter
      .filter-group(style="margin-bottom:40px;display:flex;gap:10px;flex-wrap:wrap;")
        button.filter-chip.active Tất cả
        button.filter-chip Xu hướng
        button.filter-chip Phong cách sống
        button.filter-chip Vật liệu
        button.filter-chip Dự án
        button.filter-chip Mẹo hay

      // Featured article
      .blog-featured(style="margin-bottom:40px;")
        .blog-img-wrap(style="aspect-ratio:16/10;")
          img(src="https://i.pinimg.com/1200x/a8/4f/1c/a84f1ced741e0226e27e2680eee64502.jpg" alt="Design Talk" style="width:100%;height:100%;object-fit:cover;")
        
        .blog-body
          span.news-cat(style="position:static;margin-bottom:16px;display:inline-flex;align-self:flex-start;") Xu hướng
          
          .news-meta
            span 30/10/2024
            span 208 lượt xem
          
          h2(style="font-size:1.6rem;font-weight:800;margin:12px 0;line-height:1.3;")
            a(href="#" style="color:var(--primary);") Design Talk – Chuyện trò về những xu hướng nội thất đang làm mưa làm gió
          
          p(style="color:var(--text-light);line-height:1.8;margin-bottom:20px;")
            | Xu hướng chính là những gì được nhiều người quan tâm đến trong một khoảng thời gian nhất định...
          
          a.btn.btn-gold(href="#") Đọc tiếp →

      // Blog grid
      .blog-grid

        article.news-card
          a.news-img-link(href="#")
            img(src="https://i.pinimg.com/1200x/99/4f/04/994f04bde1b4e59db8e25eed8eb61093.jpg" alt="Lagom")
            span.news-cat Phong cách sống

          
          .news-body
            .news-meta
              span 30/10/2024
              span 195 lượt xem
            
            h3
              a(href="#") Mang làn gió Lagom đến không gian sống của bạn
            
            p Lagom, một thuật ngữ không còn quá xa lạ...
            
