extend ../layouts/default.pug

block content
  .page-hero(style="padding:40px 0;")
    .container
      h1 Quên mật khẩu
      nav.breadcrumb
        a(href="index.html") Trang chủ
        span ›
        span Quên mật khẩu
  section.auth-wrap
    .auth-box
      // Step Indicator
      .step-indicator
        #step1Indicator.step-item(class= step === 1 ? 'active' : '')
          .step-number 1
          span Xác minh

        #step2Indicator.step-item(class= step === 2 ? 'active' : '')
          .step-number 2
          span Nhập OTP

        #step3Indicator.step-item(class= step === 3 ? 'active' : '')
          .step-number 3
        span Đặt lại mật khẩu
      // Step 1: Enter Email/Phone
      #step1.form-step.active
        div(style="text-align:center;margin-bottom:32px;")
          div(style="font-size:2rem;font-weight:900;color:var(--primary);")
            span MANHQUYNH!
            span(style="font-weight:300;") Decor.
          p(style="font-size:0.9rem;color:var(--text-light);margin-top:8px;") Nhập email hoặc số điện thoại để xác minh
        form#forgotPasswordForm
          .form-group
            label(for="email") Email / Số điện thoại
            input#email.form-control(
              required="" 
              name="email"
              placeholder="example@email.com hoặc 0901234567" 
              type="text"
              )
          button.btn.btn-gold(
            style="width:100%;justify-content:center;padding:16px;" 
            type="submit"
            ) Gửi mã xác minh
        div(style="text-align:center;margin-top:24px;")
          p(style="font-size:0.88rem;color:var(--text-light);")
            | Quay lại
            a(
              style="color:var(--primary);font-weight:700;" 
              href="/account/login"
              ) Đăng nhập