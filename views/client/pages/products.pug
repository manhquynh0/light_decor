extends ../layouts/default.pug
include ../mixins/pagination.pug
block content
  .page-hero(style="padding:0; margin-bottom: 40px;")
    .hero-image-wrap(style="width: 100%; height: 550px; overflow: hidden;")
      img(src="/assets/images/product.png" alt="ManhQuynh" style="width: 100%; height: 100%; object-fit: cover;")
    .container(style="margin-top: -60px; position: relative; z-index: 2;")
      nav.breadcrumb(style="background: rgba(0,0,0,0.5); display: inline-flex; padding: 10px 20px; border-radius: 8px; backdrop-filter: blur(4px);")
        a(href="/home" style="color: var(--white);") Trang chủ
        span(style="color: var(--text-light); margin: 0 10px;") ›
        span(style="color: var(--accent);") Sản phẩm
  section.section
    .container
      // Category chips

      .shop-layout
        // Filter sidebar
        aside#filterPanel.filter-panel
          .filter-header-wrap
            h3(style="margin:0;") Bộ lọc
            button.filter-clear-btn(filter-reset) Xoá tất cả
          
          .filter-sidebar-search
            i.fa-solid.fa-magnifying-glass
            input(type="text" placeholder="Tìm kiếm đèn..." search)
   
          .filter-accordion.active
            .filter-accordion-header
              h3 Sắp xếp theo
              i.fa-solid.fa-chevron-down.chevron
            .filter-accordion-content
              .filter-group-inner
                label(style="display:flex;align-items:center;gap:10px;margin-bottom:10px;font-size:0.85rem;cursor:pointer;")
                  input(name="status" value="" type="radio" checked)
                  | Tất cả
                label(style="display:flex;align-items:center;gap:10px;margin-bottom:10px;font-size:0.85rem;cursor:pointer;")
                  input(name="status" value="new" type="radio")
                  | Sản phẩm mới
                label(style="display:flex;align-items:center;gap:10px;margin-bottom:10px;font-size:0.85rem;cursor:pointer;")
                  input(name="status" value="promotion" type="radio")
                  | Khuyến mãi HOT

          // Không gian
          // Danh mục động từ categoryTree
          each item in categoryTree
            .filter-accordion
              .filter-accordion-header
                h3 #{item.name}
                i.fa-solid.fa-chevron-down.chevron
              .filter-accordion-content
                .space-tag-grid
                  each child in item.children
                    .space-tag #{child.name}  


        // Product grid
        div
          .shop-header
            span(style="font-size:0.88rem;color:var(--text-light);")
              | Hiển thị 
              strong(style="color:var(--accent);") #{pagination.totalRecord}
              |  sản phẩm
            div(style="display:flex;align-items:center;gap:12px;")
              select.shop-sort-select(filter-price)
                option(value="") Mặc định
                option(value="0-10000000") Dưới 10.000.000 ₫
                option(value="10000000-20000000") 10.000.000 - 20.000.000 ₫
                option(value="20000000-30000000") 20.000.000 - 30.000.000 ₫
                option(value="30000000-") Trên 30.000.000 ₫
          .products-list-grid
            each item in products
              article.prod-card
                a.prod-img-wrap(href="#")
                  img(
                    alt="Ghế sofa văng" 
                    src=item.avatar
                    )
                  span.prod-badge - #{Number(item.priceOLD) > 0 ? Math.floor(((Number(item.priceOLD) - Number(item.priceNEW)) / Number(item.priceOLD)) * 100) : 0}%
                  .prod-overlay
                    button.quick-add Thêm giỏ hàng
                .prod-body
                  h3.prod-name
                    a(href="#") #{item.name}
                  .prod-price
                    span.price-old #{Number(item.priceOLD).toLocaleString('vi-VN')} ₫
                    span.price-new #{Number(item.priceNEW).toLocaleString('vi-VN')} ₫
                  .prod-stars ★★★★★
          +pagination(pagination, products.length)