extend ../layouts/default.pug

block content
  .page-hero(style="padding:40px 0;")
    .container
      h1 Quên mật khẩu
      nav.breadcrumb
        a(href="/home") Trang chủ
        span ›
        span Quên mật khẩu
  section.auth-wrap
    .auth-box
      // Step Indicator
      .step-indicator
        #step1Indicator.step-item(class= step === 1 ? 'active' : '')
          .step-number 1
          span Xác minh

        #step2Indicator.step-item(class= step === 2 ? 'active' : '')
          .step-number 2
          span Nhập OTP

        #step3Indicator.step-item(class= step === 3 ? 'active' : '')
          .step-number 3
          span Đặt lại mật khẩu
      #step2.form-step.active
        div(style="text-align:center;margin-bottom:24px;")
          div(style="font-size:2rem;font-weight:900;color:var(--text-dark);")
            span MANHQUYNH!
            span(style="font-weight:300;color:var(--accent);") Decor.
          p(style="font-size:0.9rem;color:var(--text-light);margin-top:8px;")
            | Nhập mã OTP đã gửi đến
            span#userEmail(style="font-weight:600;color:var(--text-dark);")
          p(style="font-size:0.8rem;color:var(--text-light);margin-top:4px;")
            | Mã có hiệu lực trong
            span(style="color:var(--accent-dark);font-weight:600;margin-left:6px;") 5 phút
        form#otpPasswordForm
          .otp-inputs
            input(type="hidden" name="otp" id="otp")
            input.otp-digit(
              data-index="0" 
              maxlength="1" 
              type="text"
              )
            input.otp-digit(
              data-index="1" 
              maxlength="1" 
              type="text"
              )
            input.otp-digit(
              data-index="2" 
              maxlength="1" 
              type="text"
              )
            input.otp-digit(
              data-index="3" 
              maxlength="1" 
              type="text"
              )
            input.otp-digit(
              data-index="4" 
              maxlength="1" 
              type="text"
              )
            input.otp-digit(
              data-index="5" 
              maxlength="1" 
              type="text"
              )
          #otp-countdown.countdown-timer
            span(style="color:var(--text-light);font-size:0.9rem;") OTP còn hiệu lực trong : 
            span#countdown-time(style="font-weight:bold;color:var(--accent-red);font-size:0.9rem;margin-left:6px;") 5:00
          button.btn.btn-gold(
            style="width:120px;justify-content:center;padding:16px;margin-top:16px;display : flex;margin:0 auto" 
            type="submit"
            ) Xác nhận
        div(style="text-align:center;margin-top:20px;")
          p(style="font-size:0.85rem;color:var(--text-light);margin-right:6px;")
            | Chưa nhận được mã?
            span#resendLink.resend-link Gửi lại mã
            span#resendCountdown(style="display:none;color:var(--text-light);")
              | sau
              span#resendTimer 60
              | s
        div(style="text-align:center;margin-top:16px;")
          a(
            style="font-size:0.85rem;color:var(--accent);font-weight:600;" 
            href="/account/forgot-password"
            ) ‹ Quay lại
