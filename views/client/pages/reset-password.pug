extends ./setting.pug

block main
  #panel-security.settings-panel.active

    .settings-card
      .settings-card-header
        div
          h2 Đổi mật khẩu
          p Sử dụng mật khẩu mạnh để bảo vệ tài khoản

      .settings-card-body
        form#resetPassword

          .form-group
            label(for="currentPass") Mật khẩu hiện tại
            div(style="position:relative;")
              input#currentPass.form-control(
                required
                placeholder="Nhập mật khẩu hiện tại"
                type="password"
                
                name ="currentPass"
              )
              button(
                type="button"
                data-show-pass="currentPass"
                style="position:absolute;right:14px;top:50%;transform:translateY(-50%);font-size:0.8rem;font-weight:700;color:var(--accent-dark);"
              ) Hiện

          .form-group
            label(for="newPass") Mật khẩu mới
            div(style="position:relative;")
              input#newPass.form-control(
                required
                placeholder="Tối thiểu 8 ký tự"
                type="password"
                
                name ="newPass"
              )
              button(
                type="button"
                data-show-pass="newPass"
                style="position:absolute;right:14px;top:50%;transform:translateY(-50%);color : var(--accent)"
              ) Hiện

            #passStrength.password-strength(style="display:none;")
              .strength-bar
                #strengthFill.strength-fill
              span#strengthText.strength-text Nhập mật khẩu...

          .form-group
            label(for="confirmPass") Xác nhận mật khẩu mới
            div(style="position:relative;")
              input#confirmPass.form-control(
                required
                placeholder="Nhập lại mật khẩu mới"
                type="password"
              )
              button(
                type="button"
                data-show-pass="confirmPass"
                style="position:absolute;right:14px;top:50%;transform:translateY(-50%);color : var(--accent)"
              ) Hiện

          .form-actions
            button.btn.btn-gold(type="submit")
              svg(
                stroke-width="2.5"
                stroke="currentColor"
                fill="none"
                viewBox="0 0 24 24"
                height="16"
                width="16"
              )
                rect(rx="2" height="11" width="18" y="11" x="3")
                path(d="M7 11V7a5 5 0 0 1 10 0v4")
              | Cập nhật mật khẩu

            span#passSaveOk.save-indicator ✓ Mật khẩu đã được cập nhật!

