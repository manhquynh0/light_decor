extend ../layouts/default.pug

block content
  .page-hero(style="padding:40px 0;")
    .container
      h1 Thanh toán
      // Checkout steps
      div(style="display:flex;align-items:center;justify-content:center;gap:0;margin-top:20px;")
        div(style="display:flex;align-items:center;gap:8px;")
          div(
            style="width:28px;height:28px;border-radius:50%;background:var(--accent);color:var(--primary-dark);display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:800;"
            ) 1
          span(style="font-size:0.85rem;font-weight:700;color:var(--accent);") Giỏ hàng
        div(style="width:40px;height:2px;background:var(--accent);margin:0 8px;")
        div(style="display:flex;align-items:center;gap:8px;")
          div(
            style="width:28px;height:28px;border-radius:50%;background:var(--primary);color:white;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:800;"
            ) 2
          span(style="font-size:0.85rem;font-weight:700;color:white;") Thanh toán
        div(style="width:40px;height:2px;background:rgba(255,255,255,0.3);margin:0 8px;")
        div(style="display:flex;align-items:center;gap:8px;")
          div(
            style="width:28px;height:28px;border-radius:50%;background:rgba(255,255,255,0.15);color:rgba(255,255,255,0.5);display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:800;"
            ) 3
          span(style="font-size:0.85rem;font-weight:600;color:rgba(255,255,255,0.5);") Xác nhận
  section.section
    .container
      div(style="display:grid;grid-template-columns:1fr 400px;gap:40px;align-items:start;")
        // Form
        div
          // Shipping info
          div(
            style="background:var(--light-bg);border:1px solid var(--border);border-radius:var(--radius-xl);padding:32px;margin-bottom:24px;"
            )
            h2(
              style="font-size:1.1rem;font-weight:800;color:var(--white);margin-bottom:24px;display:flex;align-items:center;gap:10px;"
              )
              span(
                style="width:28px;height:28px;background:var(--accent);color:var(--primary-dark);border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:800;"
                ) 1
              | Thông tin giao hàng
            form(style="display:grid;gap:16px;" id="order-form")
              div(style="display:grid;grid-template-columns:1fr 1fr;gap:16px;")
                .form-group(style="margin:0;")
                  label Họ *
                  input.form-control(
                    placeholder="Nguyễn" 
                    type="text"
                    id = "firstName"
                    name = "firstName"
                    )
                .form-group(style="margin:0;")
                  label Tên *
                  input.form-control(
                    placeholder="Văn A" 
                    type="text"
                    id = "lastName"
                    name = "lastName"
                    )
              .form-group(style="margin:0;")
                label Email *
                input.form-control(
                  placeholder="example@email.com" 
                  type="email"
                  id = "email"
                  name = "email"
                  )
              .form-group(style="margin:0;")
                label Số điện thoại *
                input.form-control(
                  placeholder="0901 191 616" 
                  type="tel"
                  id = "phone"
                  name = "phone"
                  )
              .form-group(style="margin:0;")
                label Địa chỉ *
                input.form-control(
                  placeholder="Số nhà, tên đường..." 
                  type="text"
                  id = "address"
                  name = "address"
                  )
             
              .form-group(style="margin:0;")
                label Ghi chú
                textarea.form-control(
                  style="resize:vertical;" 
                  placeholder="Ghi chú về đơn hàng (không bắt buộc)" 
                  rows="3"
                  id = "note"
                  name = "note"
                  )
          // Payment method
          div(
            style="background:var(--light-bg);border:1px solid var(--border);border-radius:var(--radius-xl);padding:32px;"
            )
            h2(
              style="font-size:1.1rem;font-weight:800;color:var(--white);margin-bottom:24px;display:flex;align-items:center;gap:10px;"
              )
              span(
                style="width:28px;height:28px;background:var(--accent);color:var(--primary-dark);border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:800;"
                ) 2
              | Phương thức thanh toán
            div(style="display:grid;gap:12px;")
              label(
                style="display:flex;align-items:center;gap:14px;padding:16px;border:2px solid var(--accent);border-radius:var(--radius-md);cursor:pointer;background:rgba(212,175,55,0.05);"
                )
                input(
                  checked="" 
                  name="method" 
                  form="order-form" 
                  type="radio"
                  value = "money"
                  )
                span(style="font-weight:700;font-size:0.9rem;color:var(--white);") COD – Thanh toán khi nhận hàng
                span(
                  style="margin-left:auto;font-size:0.8rem;color:var(--accent);background:rgba(212,175,55,0.1);padding:4px 10px;border-radius:999px;font-weight:700;"
                  ) Phổ biến
              label(
                style="display:flex;align-items:center;gap:14px;padding:16px;border:2px solid var(--border);border-radius:var(--radius-md);cursor:pointer;"
                )
                input(
                  name="method" 
                  form="order-form" 
                  type="radio"
                  value = "bank"
                  )
                span(style="font-weight:700;font-size:0.9rem;color:var(--text-mid);") Chuyển khoản ngân hàng
              
              div#bank-transfer-info(style="display:none; padding:20px; background:var(--light-bg); border:1px dashed var(--border); border-radius:var(--radius-md); margin-top:-8px; margin-bottom:10px;")
               
              label(
                style="display:flex;align-items:center;gap:14px;padding:16px;border:2px solid var(--border);border-radius:var(--radius-md);cursor:pointer;"
                )
                input(
                  name="method" 
                  form="order-form" 
                  type="radio"
                  value = "vnpay"
                  )
                span(style="font-weight:700;font-size:0.9rem;color:var(--text-mid);") VNPay
              label(
                style="display:flex;align-items:center;gap:14px;padding:16px;border:2px solid var(--border);border-radius:var(--radius-md);cursor:pointer;"
                )
                input(
                  name="method" 
                  form="order-form" 
                  type="radio"
                  value = "momo"
                  )
                span(style="font-weight:700;font-size:0.9rem;color:var(--text-mid);") Ví điện tử MoMo
        // Order summary
        div(style="position:sticky;top:100px;")
          div(
            style="background:var(--light-bg);border:1px solid var(--border);border-radius:var(--radius-xl);padding:28px;"
            )
            h3(style="font-size:1rem;font-weight:800;color:var(--white);margin-bottom:20px;") Đơn hàng của bạn
            div(style="display:flex;flex-direction:column;gap:14px;margin-bottom:20px;"
              class="order-summary")
            div(
              style="border-top:1px solid var(--border);padding-top:16px;display:flex;flex-direction:column;gap:10px;"
              )
              div(
                style="display:flex;flex-direction:column;gap:10px;margin-bottom:16px;"
                )
                //- ---- Danh sách mã giảm giá hiện có ----
                if coupons && coupons.length > 0
                  div(style="margin-bottom:8px;")
                    p(style="font-size:0.78rem;font-weight:700;color:var(--accent);margin-bottom:8px;letter-spacing:0.5px;")  MÃ ƯU ĐÃI ĐANG CÓ
                    div(style="display:flex;flex-direction:column;gap:6px;max-height:180px;overflow-y:auto;padding-right:2px;")
                      each coupon in coupons
                        //- Card: flex-column để xếp [hàng code+button] và [cảnh báo] chồng lên nhau trong cùng 1 khung
                        div(style="display:flex;flex-direction:column;gap:6px;background:rgba(212,175,55,0.06);border:1px dashed rgba(212,175,55,0.35);border-radius:var(--radius-md);padding:8px 12px;")
                          //- Hàng trên: code + badge giảm giá + nút Chép
                          div(style="display:flex;align-items:center;justify-content:space-between;gap:8px;")
                            div(style="flex:1;min-width:0;")
                              div(style="display:flex;align-items:center;gap:6px;margin-bottom:2px;")
                                span(style="font-family:monospace;font-size:0.82rem;font-weight:800;color:var(--accent);letter-spacing:1px;") #{coupon.code}
                                if coupon.discountType === "percent"
                                  span(style="font-size:0.7rem;background:rgba(212,175,55,0.15);color:var(--accent);padding:1px 6px;border-radius:999px;font-weight:700;") -#{coupon.discountValue}%
                                else
                                  span(style="font-size:0.7rem;background:rgba(212,175,55,0.15);color:var(--accent);padding:1px 6px;border-radius:999px;font-weight:700;") -#{coupon.discountValue.toLocaleString("vi-VN")}đ
                              if coupon.description
                                p(style="font-size:0.7rem;color:var(--text-light);margin:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;") #{coupon.description}
                            button(
                              onclick=`copyCouponCode('${coupon.code}', this)`
                              title="Sao chép và áp dụng mã"
                              style="flex-shrink:0;display:flex;align-items:center;gap:4px;background:rgba(212,175,55,0.12);border:1px solid rgba(212,175,55,0.3);border-radius:var(--radius-sm);padding:4px 8px;cursor:pointer;color:var(--accent);font-size:0.72rem;font-weight:700;transition:all 0.2s;"
                            )
                              svg.copy-icon(stroke-width="2" stroke="currentColor" fill="none" viewBox="0 0 24 24" height="11" width="11")
                                rect(width="13" height="13" x="9" y="9" rx="2" ry="2")
                                path(d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1")
                              svg.check-icon(style="display:none" stroke-width="2.5" stroke="currentColor" fill="none" viewBox="0 0 24 24" height="11" width="11")
                                polyline(points="20 6 9 17 4 12")
                              span.copy-text Chép
                          //- Hàng dưới (chỉ hiện khi có đơn tối thiểu): cảnh báo nằm trong cùng khung với code
                          if coupon.minOrderValue > 0
                            p(style="font-size:0.68rem;color:#f87171;margin:0;padding:3px 6px;background:rgba(248,113,113,0.1);border-radius:4px;")
                              |  Đơn hàng tối thiểu #{coupon.minOrderValue.toLocaleString("vi-VN")}đ để sử dụng mã này!


                //- ---- Ô nhập mã thủ công ----
                label(style="font-size:0.85rem;font-weight:700;color:var(--text-mid);") Mã giảm giá
                div(style="display:flex;gap:10px;")
                  input#coupon-input.form-control(
                    placeholder="Nhập mã ưu đãi..." 
                    type="text"
                    style="flex:1;padding:10px 16px;text-transform:uppercase;"
                  )
                  button#apply-coupon-btn.btn.btn-gold(
                    type="button"
                    style="padding:10px 20px;font-size:0.85rem;border-radius:var(--radius-md);"
                  ) Áp dụng
                div#coupon-message(style="font-size:0.75rem;margin-top:4px;display:none;")

              div(
                style="display:flex;justify-content:space-between;font-size:0.88rem;color:var(--text-light);"
                )
                span Tạm tính
                span(style="color:var(--text-mid);" class="payment-subtotal") 0 ₫
              div#discount-row(
                style="display:none;justify-content:space-between;font-size:0.88rem;color:#4ade80;"
                )
                span Giảm giá
                span(class="payment-discount") -0 ₫
              div(
                style="display:flex;justify-content:space-between;font-size:0.88rem;color:var(--text-light);"
                )
                span Phí vận chuyển
                span(style="color:var(--text-mid);") 0 ₫
              div(
                style="display:flex;justify-content:space-between;font-size:1rem;font-weight:800;color:var(--white);border-top:1px solid var(--border);padding-top:12px;"
                )
                span Tổng cộng
                span(style="color:var(--accent);" class="payment-total") 0 ₫
            button.btn.btn-gold(type="submit" form="order-form" style="width:100%;justify-content:center;margin-top:20px;padding:16px;font-size:1rem;"   id="submit-order")  Đặt hàng ngay
            p(style="text-align:center;font-size:0.75rem;color:var(--text-light);margin-top:12px;")
              | Bằng cách đặt hàng, bạn đồng ý với 
              a(
                style="color:var(--accent);" 
                href="#"
                ) điều khoản 
              | của chúng tôi
