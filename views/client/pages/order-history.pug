extends ./setting.pug
include ../mixins/pagination
block main
  .page-hero(style="padding:40px 0;")
    .container
      h1 Lịch sử đơn hàng
      nav.breadcrumb
        a(href="/") Trang chủ
        span ›
        a(href="/account/setting") Tài khoản
        span ›
        span Lịch sử đơn hàng
  section.section
    .container
      // Filters & Sorting
      div(style="display:flex;gap:16px;margin-bottom:32px;flex-wrap:wrap;align-items:center;")
        div(style="display:flex;gap:8px;")
          select.form-control(style="width:200px;cursor:pointer;" filter-status)
            option(value="") Tất cả trạng thái
            option(value="initial") Đang xử lý
            option(value="shipped") Đã gửi hàng
            option(value="delivered") Đã giao hàng
            option(value="cancelled") Đã hủy
        div(style="display:flex;gap:8px;margin-left:auto;")
          input.form-control(
            style="width:220px;padding:12px 16px;" 
            placeholder="Tìm theo số đơn hàng..." 
            type="text"
            search
            )
          button.btn.btn-outline-dark(style="padding:12px 20px;" search) Tìm kiếm
      // Orders List
      div(style="display:grid;gap:24px;")
      
         each item in orderList
          .order-card
         
              .order-card-header
                div(style="display:grid;grid-template-columns:repeat(auto-fit, minmax(140px, 1fr));gap:20px;flex:1;")
                  div
                    p.order-meta-label  Mã đơn hàng
                    p.order-meta-val #{item.orderCode}
                  div
                    p.order-meta-label Ngày đặt hàng
                    p.order-meta-val #{item.createdAtFormat}
                  div
                    p.order-meta-label Tổng tiền
                    p(style="font-size:1.1rem;font-weight:800;color:var(--accent);") #{Number(item.total).toLocaleString('vi-VN')} ₫
                  div
                    p.order-meta-label Thanh Toán
                    if item.paymentStatus == "paid"
                      span.badge.badge-light Đã thanh toán
                    else if item.paymentStatus == "unpaid"
                      span.badge.badge-danger Chưa thanh toán

                  div
                    p.order-meta-label Trạng thái
                    if item.status == "initial"
                      span.badge.badge-light Cửa hàng đã nhận đơn
                    else if item.status == "success"
                      span.badge.badge-success Đã giao hàng
                    else if item.status == "cancelled"
                      span.badge.badge-danger Đã hủy
              each product in item.items
                .order-items
                  .order-item

                    img(src=product.avatar alt="")
                    .order-item-info
                      h4 #{product.name}
                      p Số Lượng × #{product.quantity}
                    p(style="font-size:0.9rem;font-weight:700;color:var(--white);margin-left:auto;") #{Number(product.price).toLocaleString('vi-VN')} ₫
                  
                .order-card-footer
                  button.btn.btn-outline-dark.btn-sm(onclick=`window.location.href='/products/${product.slug}'` style="padding:10px 16px;color:white;border-color:rgba(255,255,255,0.2);") Mua lại
                  button.btn.btn-outline-dark.btn-sm(onclick=`window.location.href='/products/${product.slug}#reviews'` style="padding:10px 16px;color:white;border-color:rgba(255,255,255,0.2);") Để lại đánh giá
      // Pagination
      +pagination(pagination, orderList.length)
  // Help Section
  section.section(style="background:var(--off-white);")
    .container
      div(style="display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center;")
        div
          h2.section-title Cần hỗ trợ?
          p(style="color:var(--text-light);margin-top:12px;line-height:1.8;font-size:0.95rem;")
            | Nếu bạn có bất kỳ câu hỏi nào về đơn hàng của mình, chúng tôi ở đây để giúp. Liên hệ với chúng tôi qua hotline hoặc email bất kỳ lúc nào.
          div(style="display:flex;gap:12px;margin-top:24px;")
            button.btn.btn-gold(style="padding:14px 28px;") ☎️ Gọi cho chúng tôi
            button.btn.btn-outline-dark(style="padding:14px 28px;") 💬 Chat trực tuyến
        div(style="display:grid;gap:20px;")
          div(
            style="background:var(--primary);padding:24px;border-radius:var(--radius-xl);border:1px solid var(--border);"
            )
            h3(style="font-weight:800;margin-bottom:8px;color:var(--accent);") Hotline
            p(style="font-size:1.1rem;font-weight:700;color:var(--accent);")
              a(href="tel:0901191616") 0373382805
          div(
            style="background:var(--primary);padding:24px;border-radius:var(--radius-xl);border:1px solid var(--border);"
            )
            h3(style="font-weight:800;margin-bottom:8px;color:var(--accent);") Email
            p(style="font-size:1rem;font-weight:600;color:var(---accent);")
              a(href="mailto:support@MANHQUYNHdecor.vn") vmquynh.dhti17a3@sv.uneti.edu.vn