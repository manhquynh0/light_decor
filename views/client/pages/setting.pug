extends ../layouts/default.pug

block content
  .page-hero(style="padding:36px 0;")
    .container
      h1 Cài đặt tài khoản
      nav.breadcrumb
        a(href="/home") Trang chủ
        span  › 
        span Cài đặt

  .settings-page
    .container
      .settings-layout
        // SIDEBAR
        aside.settings-sidebar
          // User Card
          .user-card
            .user-avatar-wrap
              img#userAvatarImg.user-avatar-img(style=(user.avatar ? "display:flex;" : "display:none;") alt="Avatar" src=user.avatar)
              #avatarInitials.avatar-initials(style=(user.avatar ? "display:none;" : "display:flex;")) #{user.fullname ? user.fullname.charAt(0).toUpperCase() : 'U'}
              input#avatarUpload.avatar-upload-input(accept="image/*" type="file")
              button.avatar-edit-btn(onclick="document.getElementById('avatarUpload').click()" title="Đổi ảnh đại diện")
                svg(stroke-width="2.5" stroke="white" fill="none" viewBox="0 0 24 24" height="12" width="12")
                  path(d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7")
                  path(d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z")
            #sidebar-name.user-card-name #{user.fullname}
            .user-card-email #{user.email}
            span.user-role-badge.role-admin
              svg(fill="currentColor" viewBox="0 0 24 24" height="10" width="10")
                path(d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z")
              |  #{user.roleName}

          // Nav
          nav#settingsNav.settings-nav
            .settings-nav-group
              .settings-nav-label Tài khoản
              button#nav-profile.settings-nav-item(onclick="window.location.href='/account/setting/information'")
                svg(stroke-width="2" stroke="currentColor" fill="none" viewBox="0 0 24 24" height="16" width="16")
                  path(d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2")
                  circle(r="4" cy="7" cx="12")
                |  Thông tin cá nhân
              button#nav-security.settings-nav-item(onclick="window.location.href='/account/setting/reset-password'")
                svg(stroke-width="2" stroke="currentColor" fill="none" viewBox="0 0 24 24" height="16" width="16")
                  rect(ry="2" rx="2" height="11" width="18" y="11" x="3")
                  path(d="M7 11V7a5 5 0 0 1 10 0v4")
                |  Bảo mật & Mật khẩu
              button#nav-notifications.settings-nav-item(onclick="window.location.href='/account/setting/notification'")
                svg(stroke-width="2" stroke="currentColor" fill="none" viewBox="0 0 24 24" height="16" width="16")
                  path(d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9")
                  path(d="M13.73 21a2 2 0 0 1-3.46 0")
                |  Thông báo
              button#nav-orders-history.settings-nav-item(onclick="window.location.href='/account/setting/orders-history'")
                svg(stroke-width="2" stroke="currentColor" fill="none" viewBox="0 0 24 24" height="16" width="16")
                  path(d="M12 8v4l3 3")
                  path(d="M21 12a9 9 0 1 1-6.219-8.56")
                |  Lịch Sử Đơn hàng
            if permissions && permissions.includes("admin")
              #adminNavGroup.settings-nav-group
                .settings-nav-label Quản trị
                button#nav-admin.settings-nav-item(onclick=`window.location.href='${prefixAdmin}/dashboard'`)
                  svg(stroke-width="2" stroke="currentColor" fill="none" viewBox="0 0 24 24" height="16" width="16")
                    rect(height="7" width="7" y="3" x="3")
                    rect(height="7" width="7" y="3" x="14")
                    rect(height="7" width="7" y="14" x="14")
                    rect(height="7" width="7" y="14" x="3")
                  |  Bảng quản trị
                  span.admin-tab-badge(style="margin-left:auto;") ADMIN

            .settings-nav-group
              button#nav-logout.settings-nav-item.nav-item-danger(onclick="openModal('logoutModal')")
                svg(stroke-width="2" stroke="currentColor" fill="none" viewBox="0 0 24 24" height="16" width="16")
                  path(d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4")
                  polyline(points="16 17 21 12 16 7")
                  line(y2="12" x2="9" y1="12" x1="21")
                |  Đăng xuất

        // MAIN PANELS (Nội dung bên phải)
        #settingsPanels.settings-panels
          block main
            #panel-profile.settings-panel.active
              .settings-card
                .settings-card-header
                  div
                    h2 Thông tin cá nhân
                    p Cập nhật thông tin hiển thị trên tài khoản của bạn
                .settings-card-body
                  form#profileForm
                    .form-row(style="margin-bottom:20px; display:flex; gap:15px;")
                      .form-group(style="flex:1; margin:0;")
                        label(for="firstName") Họ
                        input#firstName.form-control(value=user.firstname type="text")
                      .form-group(style="flex:1; margin:0;")
                        label(for="lastName") Tên
                        input#lastName.form-control(value=user.lastname type="text")
                    .form-group
                      label(for="profileEmail") Email
                      input#profileEmail.form-control(value=user.email type="email")
                    .form-group
                      label(for="profilePhone") Số điện thoại
                      input#profilePhone.form-control(placeholder="+84 xxx xxx xxx" value=user.phone type="tel")
                    .form-group
                      label(for="profileBio") Giới thiệu ngắn
                      textarea#profileBio.form-control(placeholder="Viết vài dòng giới thiệu về bạn..." rows="3") #{user.role}
                    .form-row(style="margin-bottom:20px; display:flex; gap:15px;")
                      .form-group(style="flex:1; margin:0;")
                        label(for="profileCity") Thành phố
                        select#profileCity.form-control
                          option Hà Nội
                          option(selected="") TP. Hồ Chí Minh
                          option Đà Nẵng
                          option Cần Thơ
                      .form-group(style="flex:1; margin:0;")
                        label(for="profileGender") Giới tính
                        select#profileGender.form-control
                          option(selected="") Nam
                          option Nữ
                          option Khác
                    .form-actions
                      button#saveProfileBtn.btn.btn-gold(type="submit")
                        svg(stroke-width="2.5" stroke="currentColor" fill="none" viewBox="0 0 24 24" height="16" width="16" style="margin-right:8px; vertical-align:middle;")
                          path(d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z")
                          polyline(points="17 21 17 13 7 13 7 21")
                          polyline(points="7 3 7 8 15 8")
                        | Lưu thay đổi
                      span#profileSaveOk.save-indicator  ✓ Đã lưu thành công!

  // Logout Modal (Đặt ngoài container chính để tránh lỗi CSS overflow)
  #logoutModal.modal-backdrop
    .modal-box
      .modal-header
        h3 Đăng xuất khỏi MANHQUYNH!Decor
        button.modal-close(onclick="closeModal('logoutModal')") ✕
      .modal-body
        .logout-card
          .logout-icon
            svg(stroke-width="2" stroke="currentColor" fill="none" viewBox="0 0 24 24" height="28" width="28")
              path(d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4")
              polyline(points="16 17 21 12 16 7")
              line(y2="12" x2="9" y1="12" x1="21")
          p Bạn có chắc chắn muốn đăng xuất không? Phiên làm việc hiện tại sẽ kết thúc.
          div(style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;")
            button#logoutConfirmBtn.btn.btn-gold(onclick="confirmLogout()")
              svg(stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" height="16" width="16" style="display:inline-block; vertical-align:middle; margin-right:8px;")
                path(d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4")
                polyline(points="16 17 21 12 16 7")
                line(x1="21" y1="12" x2="9" y2="12")
              | Xác nhận đăng xuất
            button.btn.btn-outline-dark(onclick="closeModal('logoutModal')" style="color:white;border-color:rgba(255,255,255,0.3);") Hủy
