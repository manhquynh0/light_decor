extends ../layouts/default.pug

block content
  .page-hero(style="padding:36px 0;")
    .container
      h1 Cài đặt tài khoản
      nav.breadcrumb
        a(href="index.html") Trang chủ
        span ›
        span Cài đặt

  .settings-page
    .container
      .settings-layout
        // SIDEBAR
        aside.settings-sidebar
          // User Card
          .user-card
            .user-avatar-wrap
              img#userAvatarImg.user-avatar-img(
                style="display:none;"
                alt="Avatar"
                src=""
              )
              #avatarInitials.avatar-initials NT
              input#avatarUpload.avatar-upload-input(
                accept="image/*"
                type="file"
              )
              button.avatar-edit-btn(
                onclick="document.getElementById('avatarUpload').click()"
                title="Đổi ảnh đại diện"
              )
                svg(
                  stroke-width="2.5"
                  stroke="white"
                  fill="none"
                  viewBox="0 0 24 24"
                  height="12"
                  width="12"
                )
                  path(d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7")
                  path(d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z")
            #sidebar-name.user-card-name Nguyễn Thành
            .user-card-email admin@ohdecor.vn
            span.user-role-badge.role-admin
              svg(
                fill="currentColor"
                viewBox="0 0 24 24"
                height="10"
                width="10"
              )
                path(d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z")
              | Quản trị viên

          // Nav
          nav#settingsNav.settings-nav
            .settings-nav-group
              .settings-nav-label Tài khoản
              button#nav-profile.settings-nav-item( onclick="window.location.href='/account/setting/information'")
                svg(
                  stroke-width="2"
                  stroke="currentColor"
                  fill="none"
                  viewBox="0 0 24 24"
                  height="16"
                  width="16"
                )
                  path(d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2")
                  circle(r="4" cy="7" cx="12")
                | Thông tin cá nhân
              button#nav-security.settings-nav-item(onclick="window.location.href='/account/setting/reset-password'")
                svg(
                  stroke-width="2"
                  stroke="currentColor"
                  fill="none"
                  viewBox="0 0 24 24"
                  height="16"
                  width="16"
                )
                  rect(ry="2" rx="2" height="11" width="18" y="11" x="3")
                  path(d="M7 11V7a5 5 0 0 1 10 0v4")
                | Bảo mật & Mật khẩu
              button#nav-notifications.settings-nav-item(onclick="window.location.href='/account/setting/notification'")
                svg(
                  stroke-width="2"
                  stroke="currentColor"
                  fill="none"
                  viewBox="0 0 24 24"
                  height="16"
                  width="16"
                )
                  path(d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9")
                  path(d="M13.73 21a2 2 0 0 1-3.46 0")
                | Thông báo
              button#nav-orders-history.settings-nav-item(onclick="window.location.href='/account/setting/orders-history'")
                svg(
                  stroke-width="2"
                  stroke="currentColor"
                  fill="none"
                  viewBox="0 0 24 24"
                  height="16"
                  width="16"
                )
                  path(d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9")
                  path(d="M13.73 21a2 2 0 0 1-3.46 0")
                | Lịch Sử Đơn hàng

            #adminNavGroup.settings-nav-group
              .settings-nav-label Quản trị
              button#nav-admin.settings-nav-item(onclick="window.location.href='/admin/dashboard'")
                svg(
                  stroke-width="2"
                  stroke="currentColor"
                  fill="none"
                  viewBox="0 0 24 24"
                  height="16"
                  width="16"
                )
                  rect(height="7" width="7" y="3" x="3")
                  rect(height="7" width="7" y="3" x="14")
                  rect(height="7" width="7" y="14" x="14")
                  rect(height="7" width="7" y="14" x="3")
                | Bảng quản trị
                span.admin-tab-badge(style="margin-left:auto;") ADMIN

            .settings-nav-group
              button#nav-logout.settings-nav-item.nav-item-danger(data-panel="logout")
                svg(
                  stroke-width="2"
                  stroke="currentColor"
                  fill="none"
                  viewBox="0 0 24 24"
                  height="16"
                  width="16"
                )
                  path(d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4")
                  polyline(points="16 17 21 12 16 7")
                  line(y2="12" x2="9" y1="12" x1="21")
                | Đăng xuất

