extend ../layouts/default.pug

block content
  .page-hero(style="padding:40px 0;")
    .container
      h1 Đăng nhập
      nav.breadcrumb
        a(href="index.html") Trang chủ
        span ›
        span Đăng nhập
  section.auth-wrap
    .auth-box
      div(style="text-align:center;margin-bottom:32px;")
        div(style="font-size:2rem;font-weight:900;color:var(--primary);")
          span OH!
          span(style="font-weight:300;") Decor.
        p(style="font-size:0.9rem;color:var(--text-light);margin-top:8px;") Chào mừng trở lại! Đăng nhập để tiếp tục.
      form#loginForm
        .form-group
          label(for="loginEmail") Email / Số điện thoại
          input#email.form-control(
            required="" 
            placeholder="example@email.com" 
            type="email"
            )
        .form-group
          label(for="loginPassword") Mật khẩu
          div(style="position:relative;")
            input#password.form-control(
              required="" 
              placeholder="Nhập mật khẩu" 
              type="password"
              )
            button(
              style="position:absolute;right:14px;top:50%;transform:translateY(-50%);font-size:0.8rem;font-weight:700;color:var(--accent-dark);" 
              data-show-pass="loginPassword" 
              type="button"
              ) Hiện
        div(style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;")
          label(style="display:flex;align-items:center;gap:8px;font-size:0.85rem;cursor:pointer;")
            input(type="checkbox"  id="remember-password" name ="rememberPassword")
            | Ghi nhớ đăng nhập
          a(
            style="font-size:0.85rem;color:var(--accent-dark);font-weight:600;" 
            href="#"
            ) Quên mật khẩu?
        button.btn.btn-gold(
          style="width:100%;justify-content:center;padding:16px;" 
          type="submit"
          ) Đăng nhập
      div(
        style="text-align:center;margin-top:24px;padding-top:20px;border-top:1px solid var(--border);"
        )
        p(style="font-size:0.88rem;color:var(--text-light);")
          | Chưa có tài khoản?
          a(
            style="color:var(--primary);font-weight:700;" 
            href="/account/register"
            ) Đăng ký ngay
      div(style="margin-top:20px;")
        div(style="display:flex;align-items:center;gap:12px;margin-bottom:16px;")
          div(style="flex:1;height:1px;background:var(--border);")
          span(style="font-size:0.78rem;color:var(--text-light);white-space:nowrap;") Hoặc đăng nhập với
          div(style="flex:1;height:1px;background:var(--border);")
        div(style="display:grid;grid-template-columns:1fr 1fr;gap:12px;")
          button.btn.btn-outline-dark(style="justify-content:center;gap:8px;padding:12px;")
            svg(
              viewBox="0 0 24 24" 
              height="18" 
              width="18"
              )
              path(
                fill="#4285F4" 
                d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                )
              path(
                fill="#34A853" 
                d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                )
              path(
                fill="#FBBC05" 
                d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                )
              path(
                fill="#EA4335" 
                d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                )
            | Google
          button.btn.btn-outline-dark(style="justify-content:center;gap:8px;padding:12px;")
            svg(
              fill="#1877F2" 
              viewBox="0 0 24 24" 
              height="18" 
              width="18"
              )
              path(
                d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
                )
            | Facebook
      // User Info Section (shown after login)
      #userInfoSection.user-info-section(style="display:none;margin-top:32px;padding-top:24px;border-top:1px solid var(--border);")
        div(style="text-align:center;")
          #userInfoAvatar.user-info-avatar(
            style="width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;"
            )
            span#userInitials(style="font-size:1.8rem;font-weight:900;color:var(--accent);") NQ
          .user-info-logo(
            style="display:flex;align-items:center;justify-content:center;gap:4px;margin-bottom:12px;"
            )
            span(style="font-size:1.4rem;font-weight:900;color:var(--primary);") MANHQUYNH
            span(style="font-size:1.4rem;font-weight:300;color:var(--accent-dark);") Decor.
          #userInfoName.user-info-name(style="font-size:1.1rem;font-weight:800;color:var(--text-dark);margin-bottom:8px;") Nguyễn Quỳnh
          #userInfoRole.user-info-role(
            style="display:inline-flex;align-items:center;gap:6px;padding:6px 16px;border-radius:999px;font-size:0.75rem;font-weight:800;text-transform:uppercase;letter-spacing:0.05em;background:rgba(234,191,132,0.2);color:var(--accent-dark);"
            )
            svg(
              fill="currentColor" 
              viewBox="0 0 24 24" 
              height="14" 
              width="14"
              )
              path(
                d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"
                )
            | Quản trị viên