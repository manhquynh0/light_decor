extend ../layouts/default.pug

block content
  .page-hero(style="padding:0; margin-bottom: 40px;")
    .hero-image-wrap(style="width: 100%; height: 100%; overflow: hidden;")
      img(src="/assets/images/about.png" alt="ManhQuynh" style="width: 100%; height: 100%; object-fit: cover;")
    .container(style="margin-top: -60px; position: relative; z-index: 2;")
      nav.breadcrumb(style="background: rgba(0,0,0,0.5); display: inline-flex; padding: 10px 20px; border-radius: 8px; backdrop-filter: blur(4px);")
        a(href="/home" style="color: var(--white);") Trang chủ
        span(style="color: var(--text-light); margin: 0 10px;") ›
        span(style="color: var(--accent);") Về chúng tôi

  // About split
  section.section
    .container
      .about-hero-split
        div
          p.section-eyebrow Câu chuyện của chúng tôi
          h2.section-title(style="margin-bottom:20px;")
            | Nội thất nâng tầm
            br
            em(style="font-style:italic;font-weight:300;color:var(--accent-dark);") không gian sống
          p(style="color:var(--text-mid);line-height:1.9;margin-bottom:16px;font-size:0.95rem;")
            | OH!Decor được thành lập năm 2014 với sứ mệnh mang đến những sản phẩm nội thất cao cấp, được thiết kế tỉ mỉ và sản xuất từ các vật liệu tốt nhất. Chúng tôi tin rằng không gian sống phản ánh cá tính và gu thẩm mỹ của chủ nhân.
          p(style="color:var(--text-mid);line-height:1.9;margin-bottom:28px;font-size:0.95rem;")
            | Từ một xưởng sản xuất nhỏ tại Hà Nội, OH!Decor đã phát triển thành một trong những thương hiệu nội thất uy tín hàng đầu Việt Nam, với hơn 5.000 khách hàng hài lòng và 200+ dự án biệt thự, căn hộ cao cấp đã hoàn thành.
          div(style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-bottom:32px;")
            div(
              style="text-align:center;padding:20px;background:var(--off-white);border-radius:var(--radius-lg);"
              )
              div(style="font-size:2rem;font-weight:900;color:var(--accent-dark);") 10+
              div(
                style="font-size:0.8rem;color:var(--text-light);font-weight:600;text-transform:uppercase;letter-spacing:.06em;margin-top:4px;"
                ) Năm kinh nghiệm
            div(
              style="text-align:center;padding:20px;background:var(--off-white);border-radius:var(--radius-lg);"
              )
              div(style="font-size:2rem;font-weight:900;color:var(--accent-dark);") 5000+
              div(
                style="font-size:0.8rem;color:var(--text-light);font-weight:600;text-transform:uppercase;letter-spacing:.06em;margin-top:4px;"
                ) Khách hàng
            div(
              style="text-align:center;padding:20px;background:var(--off-white);border-radius:var(--radius-lg);"
              )
              div(style="font-size:2rem;font-weight:900;color:var(--accent-dark);") 200+
              div(
                style="font-size:0.8rem;color:var(--text-light);font-weight:600;text-transform:uppercase;letter-spacing:.06em;margin-top:4px;"
                ) Dự án
          a.btn.btn-gold(href="/contact") Liên hệ với chúng tôi
        div(style="border-radius:var(--radius-xl);overflow:hidden;height:560px;")
          img(
            style="width:100%;height:100%;object-fit:cover;" 
            alt="OH!Decor showroom" 
            src="https://cdn3729.cdn-template-4s.com/thumbs/du-an/ascentia-viethome-8_thumb_720.jpg"
            )
  // Values
  section.section(style="background:var(--off-white);")
    .container
      .section-head.center
        p.section-eyebrow Giá trị cốt lõi
        h2.section-title Tại sao chọn OH!Decor?
        p.section-desc Chúng tôi cam kết mang đến trải nghiệm tốt nhất từ thiết kế đến sản xuất và lắp đặt
      .values-grid
        .value-card
          .value-icon ✦
          h3(style="font-size:1.05rem;font-weight:700;margin-bottom:10px;color:var(--primary);") Chất lượng cao cấp
          p(style="font-size:0.88rem;color:var(--text-light);line-height:1.7;")
            | Mỗi sản phẩm đều được kiểm soát chất lượng nghiêm ngặt, chỉ sử dụng nguyên liệu tốt nhất từ các nhà cung cấp uy tín trong và ngoài nước.
        .value-card
          .value-icon ◈
          h3(style="font-size:1.05rem;font-weight:700;margin-bottom:10px;color:var(--primary);") Thiết kế cá nhân hóa
          p(style="font-size:0.88rem;color:var(--text-light);line-height:1.7;")
            | Đội ngũ thiết kế chuyên nghiệp của chúng tôi sẽ lắng nghe và biến ý tưởng của bạn thành hiện thực, phù hợp với phong cách riêng.
        .value-card
          .value-icon ❋
          h3(style="font-size:1.05rem;font-weight:700;margin-bottom:10px;color:var(--primary);") Dịch vụ trọn gói
          p(style="font-size:0.88rem;color:var(--text-light);line-height:1.7;")
            | Từ thiết kế, sản xuất đến vận chuyển và lắp đặt, chúng tôi cung cấp dịch vụ trọn gói với bảo hành dài hạn.
        .value-card
          .value-icon ⬡
          h3(style="font-size:1.05rem;font-weight:700;margin-bottom:10px;color:var(--primary);") Giao hàng đúng hẹn
          p(style="font-size:0.88rem;color:var(--text-light);line-height:1.7;")
            | Chúng tôi cam kết giao hàng đúng tiến độ cam kết, đảm bảo mọi sản phẩm đến tay bạn trong tình trạng hoàn hảo nhất.
        .value-card
          .value-icon ◎
          h3(style="font-size:1.05rem;font-weight:700;margin-bottom:10px;color:var(--primary);") Giá cạnh tranh
          p(style="font-size:0.88rem;color:var(--text-light);line-height:1.7;")
            | Chính sách giá minh bạch, cạnh tranh. Chúng tôi luôn cố gắng mang lại giá trị tốt nhất cho từng đồng tiền của khách hàng.
        .value-card
          .value-icon ★
          h3(style="font-size:1.05rem;font-weight:700;margin-bottom:10px;color:var(--primary);") Hỗ trợ sau bán hàng
          p(style="font-size:0.88rem;color:var(--text-light);line-height:1.7;")
            | Đội ngũ hỗ trợ khách hàng 24/7, sẵn sàng giải đáp mọi thắc mắc và xử lý bảo hành nhanh chóng, chuyên nghiệp.
  // Team
  section.section
    .container
      .section-head.center
        p.section-eyebrow Đội ngũ
        h2.section-title Những người tạo nên MANHQUYNH!Decor
      div(style="display:grid;grid-template-columns:repeat(4,1fr);gap:28px;")
        div(style="text-align:center;")
          div(
            style="width:120px;height:120px;border-radius:50%;overflow:hidden;margin:0 auto 16px;border:4px solid var(--accent-light);"
            )
            img(
              style="width:100%;height:100%;object-fit:cover;" 
              alt="CEO" 
              src="/assets/images/av1.jpg"
              )
          h3(style="font-size:1rem;font-weight:700;color:var(--primary);margin-bottom:4px;") Vũ Mạnh Quỳnh
          span(style="font-size:0.8rem;color:var(--accent-dark);font-weight:600;") CEO & Founder
          p(style="font-size:0.82rem;color:var(--text-light);margin-top:8px;line-height:1.6;") 10+ năm kinh nghiệm trong ngành nội thất cao cấp
        div(style="text-align:center;")
          div(
            style="width:120px;height:120px;border-radius:50%;overflow:hidden;margin:0 auto 16px;border:4px solid var(--accent-light);"
            )
            img(
              style="width:100%;height:100%;object-fit:cover;" 
              alt="Designer" 
              src="/assets/images/nghia.png"
              )
          h3(style="font-size:1rem;font-weight:700;color:var(--primary);margin-bottom:4px;") Nguyễn Đức Nghĩa
          span(style="font-size:0.8rem;color:var(--accent-dark);font-weight:600;") Giám đốc sáng tạo
          p(style="font-size:0.82rem;color:var(--text-light);margin-top:8px;line-height:1.6;") Chuyên gia thiết kế nội thất Bắc Âu và Japandi
        div(style="text-align:center;")
          div(
            style="width:120px;height:120px;border-radius:50%;overflow:hidden;margin:0 auto 16px;border:4px solid var(--accent-light);"
            )
            img(
              style="width:100%;height:100%;object-fit:cover;" 
              alt="Operations" 
              src="/assets/images/thanh.jpg"
              )
          h3(style="font-size:1rem;font-weight:700;color:var(--primary);margin-bottom:4px;") Đỗ Văn Thành
          span(style="font-size:0.8rem;color:var(--accent-dark);font-weight:600;") Giám đốc vận hành
          p(style="font-size:0.82rem;color:var(--text-light);margin-top:8px;line-height:1.6;") Đảm bảo chất lượng và tiến độ mọi dự án
        div(style="text-align:center;")
          div(
            style="width:120px;height:120px;border-radius:50%;overflow:hidden;margin:0 auto 16px;border:4px solid var(--accent-light);background:var(--light-bg);display:flex;align-items:center;justify-content:center;"
            )
            span(style="font-size:2.5rem;color:var(--accent);") +
          h3(style="font-size:1rem;font-weight:700;color:var(--primary);margin-bottom:4px;") Bạn?
          span(style="font-size:0.8rem;color:var(--accent-dark);font-weight:600;") Ứng viên tiềm năng
          p(style="font-size:0.82rem;margin-top:8px;")
            a(
              style="color:var(--primary);font-weight:700;" 
              href="contact.html"
              ) Gia nhập đội ngũ →
  // CTA
  section.section.cta-section
    .container
      .cta-box
        .cta-copy
          h2 Bắt đầu dự án của bạn
          p Hãy chia sẻ ý tưởng của bạn và đội ngũ chuyên gia của chúng tôi sẽ tư vấn miễn phí.
        a.btn.btn-gold(href="contact.html") Tư vấn ngay →
