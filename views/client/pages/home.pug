extend ../layouts/default.pug

block content
  main
    // HERO SECTION
    section.hero
      .hero-content-wrapper
        .hero-left
          .hero-copy
            span.hero-eyebrow Đèn Trang Trí
            h1.hero-title
              | Nâng tầm không
              br
              | gian sống
            p.hero-desc
              | Khám phá ộ sưu tập đèn trang trí hiện đại mang đến cảm giác thoải mái, sang trọng. Cá nhân
              |   hoá trong từng sản phẩm phù hợp với mọi không gian sống.
            a.btn.btn-gold(href="/products")
              svg(
                stroke-width="2" 
                stroke="currentColor" 
                fill="none" 
                viewBox="0 0 24 24" 
                height="18" 
                width="18"
                )
                path(d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z")
                line(
                  y2="6" 
                  x2="21" 
                  y1="6" 
                  x1="3"
                  )
                path(d="M16 10a4 4 0 0 1-8 0")
              | Mua sắm ngay
          .hero-stats
            .hero-stat
              span.stat-number 10+
              span.stat-label Năm kinh nghiệm
            .hero-stat-divider
            .hero-stat
              span.stat-number 5000+
              span.stat-label Khách hàng hài lòng
            .hero-stat-divider
            .hero-stat
              span.stat-number 200+
              span.stat-label Dự án hoàn thành
        .hero-right
          #heroCarousel.hero-carousel
            .hero-slides
              .hero-slide.active
                img(
                  alt="Nội thất hiện đại" 
                  src="https://i.pinimg.com/736x/78/11/16/7811160ca96d44a845ec1dfd8da1b4ed.jpg"
                  )
                .slide-badge Bộ sưu tập mới
              .hero-slide
                img(
                  alt="Ghế sofa vàng" 
                  src="https://i.pinimg.com/736x/78/11/16/7811160ca96d44a845ec1dfd8da1b4ed.jpg"
                  )
                .slide-badge Nổi bật
              .hero-slide
                img(
                  alt="Sofa phong cách Mỹ" 
                  src="https://i.pinimg.com/736x/78/11/16/7811160ca96d44a845ec1dfd8da1b4ed.jpg"
                  )
                .slide-badge Ưu đãi
              .hero-slide
                img(
                  alt="Không gian phòng khách" 
                  src="https://i.pinimg.com/736x/78/11/16/7811160ca96d44a845ec1dfd8da1b4ed.jpg"
                  )
                .slide-badge Hot
            .hero-slide-nav
              button#heroPrev.slide-prev(aria-label="Ảnh trước") ‹
              button#heroNext.slide-next(aria-label="Ảnh tiếp") ›
            #heroDots.hero-dots
              button.hero-dot.active(data-idx="0")
              button.hero-dot(data-idx="1")
              button.hero-dot(data-idx="2")
              button.hero-dot(data-idx="3")
