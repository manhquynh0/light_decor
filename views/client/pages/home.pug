extend ../layouts/default.pug

block content
  main
    // HERO SECTION
    section.hero
      .hero-content-wrapper
        .hero-left
          .hero-copy
            span.hero-eyebrow Đèn Trang Trí
            h1.hero-title
              | Nâng tầm không
              br
              | gian sống
            p.hero-desc
              | Khám phá ộ sưu tập đèn trang trí hiện đại mang đến cảm giác thoải mái, sang trọng. Cá nhân
              |   hoá trong từng sản phẩm phù hợp với mọi không gian sống.
            a.btn.btn-gold(href="/products")
              svg(
                stroke-width="2" 
                stroke="currentColor" 
                fill="none" 
                viewBox="0 0 24 24" 
                height="18" 
                width="18"
                )
                path(d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z")
                line(
                  y2="6" 
                  x2="21" 
                  y1="6" 
                  x1="3"
                  )
                path(d="M16 10a4 4 0 0 1-8 0")
              | Mua sắm ngay
          .hero-stats
            .hero-stat
              span.stat-number 1+
              span.stat-label Năm kinh nghiệm
            .hero-stat-divider
            .hero-stat
              span.stat-number 5000+
              span.stat-label Khách hàng hài lòng
            .hero-stat-divider
            .hero-stat
              span.stat-number 200+
              span.stat-label Sản Phẩm hoàn thành
        .hero-right
          #heroCarousel.hero-carousel
            .hero-slides
              .hero-slide.active
                img(
                  alt="" 
                  src="https://i.pinimg.com/736x/48/e9/74/48e97488e3f256f694b973ad9a58236a.jpg"
                  )
                .slide-badge Bộ sưu tập mới
              .hero-slide
                img(
                  alt="" 
                  src="https://i.pinimg.com/1200x/8f/05/e7/8f05e7608b91cef91fcd60a32b7674af.jpg"
                  )
                .slide-badge Nổi bật
              .hero-slide
                img(
                  alt="" 
                  src="https://i.pinimg.com/1200x/67/06/c9/6706c9c92eb50c40758fa6f7de6e54af.jpg"
                  )
                .slide-badge Ưu đãi
              .hero-slide
                img(
                  alt="" 
                  src="https://i.pinimg.com/736x/78/11/16/7811160ca96d44a845ec1dfd8da1b4ed.jpg"
                  )
                .slide-badge Hot
            .hero-slide-nav
              button#heroPrev.slide-prev(aria-label="Ảnh trước") ‹
              button#heroNext.slide-next(aria-label="Ảnh tiếp") ›
            #heroDots.hero-dots
              button.hero-dot.active(data-idx="0")
              button.hero-dot(data-idx="1")
              button.hero-dot(data-idx="2")
              button.hero-dot(data-idx="3")
    // CATEGORIES SLIDER
    section.section.categories-section
      .container
        .section-head
          div
            p.section-eyebrow Khám phá
            h2.section-title Các dòng sản phẩm nổi bật
        .category-slider-wrap
          button#catPrev.cat-arr.cat-arr-prev(aria-label="Trước") ‹
          #categorySlider.category-slider
            #catTrack.cat-track
              each item in products
                a.cat-card(href=`/products/${item.slug}`)
                  .cat-img-wrap
                    img(src=item.avatar)
                  .cat-info
                    h3 #{item.name}
                    span 
                    em Xem thêm →
          button#catNext.cat-arr.cat-arr-next(aria-label="Tiếp") ›
    // BỘ SƯU TẬP – TABS
    section#products.section.collection-section
      .container
        .section-head.space-between
          div
            p.section-eyebrow Bộ sưu tập
            h2.section-title Sản phẩm nổi bật
          #collectionTabs.collection-tabs
            button.coll-tab.active(data-panel="panel-modern") Hiện đại
            button.coll-tab(data-panel="panel-classic") Cổ điển
            button.coll-tab(data-panel="panel-simple") Đơn giản
            button.coll-tab(data-panel="panel-luxury") Sang trọng
        .collection-panels
          #panel-modern.coll-panel.active
            .products-grid
              each item in listModernProducts
                article.prod-card
                  a.prod-img-wrap(href=`/products/${item.slug}`)
                    img(
                      alt=""
                      src=item.avatar
                    )
                    span.prod-badge - #{Number(item.priceOLD) > 0 ? Math.floor(((Number(item.priceOLD) - Number(item.priceNEW)) / Number(item.priceOLD)) * 100) : 0}%
                    .prod-overlay
                      button.quick-add(onclick=`window.location.href='/products/${item.slug}'`)
                        svg(
                          stroke-width="2" 
                          stroke="currentColor" 
                          fill="none" 
                          viewBox="0 0 24 24" 
                          height="18" 
                          width="18"
                          )
                          path(d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z")
                          line(
                            y2="6" 
                            x2="21" 
                            y1="6" 
                            x1="3"
                            )
                          path(d="M16 10a4 4 0 0 1-8 0")
                        | Xem Chi Tiết
                  .prod-body
                    h3.prod-name
                      a(href=`/products/${item.slug}`) #{item.name}
                    .prod-price
                     span.price-old #{Number(item.priceOLD).toLocaleString('vi-VN')} ₫
                     span.price-new #{Number(item.priceNEW).toLocaleString('vi-VN')} ₫
                    .prod-stars ★★★★★
            .products-view-all
              a.btn.btn-outline-dark(href="/products") Xem thêm sản phẩm
          #panel-classic.coll-panel
            .products-grid
              each item in listClassicProducts
                article.prod-card
                  a.prod-img-wrap(href=`/products/${item.slug}`)
                    img(
                      alt=""
                      src=item.avatar
                    )
                    span.prod-badge - #{Number(item.priceOLD) > 0 ? Math.floor(((Number(item.priceOLD) - Number(item.priceNEW)) / Number(item.priceOLD)) * 100) : 0}%
                    .prod-overlay
                      button.quick-add(onclick=`window.location.href='/products/${item.slug}'`)
                        svg(
                          stroke-width="2" 
                          stroke="currentColor" 
                          fill="none" 
                          viewBox="0 0 24 24" 
                          height="18" 
                          width="18"
                          )
                          path(d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z")
                          line(
                            y2="6" 
                            x2="21" 
                            y1="6" 
                            x1="3"
                            )
                          path(d="M16 10a4 4 0 0 1-8 0")
                        | Xem Chi Tiết
                  .prod-body
                    h3.prod-name
                      a(href="/products") #{item.name}
                    .prod-price
                     span.price-old #{Number(item.priceOLD).toLocaleString('vi-VN')} ₫
                     span.price-new #{Number(item.priceNEW).toLocaleString('vi-VN')} ₫
                    .prod-stars ★★★★★
          #panel-simple.coll-panel
            .products-grid
              each item in listSimpleProducts
                article.prod-card
                  a.prod-img-wrap(href=`/products/${item.slug}`)
                    img(
                      alt=""
                      src=item.avatar
                    )
                    span.prod-badge - #{Number(item.priceOLD) > 0 ? Math.floor(((Number(item.priceOLD) - Number(item.priceNEW)) / Number(item.priceOLD)) * 100) : 0}%
                    .prod-overlay
                      button.quick-add(onclick=`window.location.href='/products/${item.slug}'`)
                        svg(
                          stroke-width="2" 
                          stroke="currentColor" 
                          fill="none" 
                          viewBox="0 0 24 24" 
                          height="18" 
                          width="18"
                          )
                          path(d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z")
                          line(
                            y2="6" 
                            x2="21" 
                            y1="6" 
                            x1="3"
                            )
                          path(d="M16 10a4 4 0 0 1-8 0")
                        | Xem Chi Tiết
                  .prod-body
                    h3.prod-name
                      a(href=`/products/${item.slug}`) #{item.name}
                    .prod-price
                     span.price-old #{Number(item.priceOLD).toLocaleString('vi-VN')} ₫
                     span.price-new #{Number(item.priceNEW).toLocaleString('vi-VN')} ₫
                    .prod-stars ★★★★★
          #panel-luxury.coll-panel
            .products-grid
              each item in listLuxuryProducts
                article.prod-card
                  a.prod-img-wrap(href=`/products/${item.slug}`)
                    img(
                      alt=""
                      src=item.avatar
                    )
                    span.prod-badge - #{Number(item.priceOLD) > 0 ? Math.floor(((Number(item.priceOLD) - Number(item.priceNEW)) / Number(item.priceOLD)) * 100) : 0}%
                    .prod-overlay
                      button.quick-add(onclick=`window.location.href='/products/${item.slug}'`)
                        svg(
                          stroke-width="2" 
                          stroke="currentColor" 
                          fill="none" 
                          viewBox="0 0 24 24" 
                          height="18" 
                          width="18"
                          )
                          path(d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z")
                          line(
                            y2="6" 
                            x2="21" 
                            y1="6" 
                            x1="3"
                            )
                          path(d="M16 10a4 4 0 0 1-8 0")
                        | Xem Chi Tiết
                  .prod-body
                    h3.prod-name
                      a(href=`/products/${item.slug}`) #{item.name}
                    .prod-price
                     span.price-old #{Number(item.priceOLD).toLocaleString('vi-VN')} ₫
                     span.price-new #{Number(item.priceNEW).toLocaleString('vi-VN')} ₫
                    .prod-stars ★★★★★    
    // INSPIRATION BANNER
    section.inspiration-section
      .inspiration-inner
        .inspiration-bg
          img(src="/assets/images/banner.png")
        .inspiration-overlay
        .inspiration-content.container
          p.insp-eyebrow MANHQUYNH!Decor
          h2.insp-title
            | NGUỒN CẢM HỨNG
            br
            em VÔ TẬN
          p.insp-desc
            | Khám phá nội thất thiết kế đương đại mang đến cảm giác thoải mái, sang trọng. Cá nhân hoá
            |   trong từng sản phẩm phù hợp với mọi không gian sống.
          a.btn.btn-gold(href="/products") Khám phá ngay
    // PRODUCT SHOWCASE 1: PHÒNG KHÁCH
    section.section.showcase-section
      .container
        .showcase-layout
          .showcase-products
            .section-head
              div
                p.section-eyebrow Phòng khách
                h2.section-title Tinh Tế & Sang Trọng
              a.btn.btn-outline-dark.btn-sm(href="/products") Xem tất cả
            .showcase-prod-list
              each item in listLivingProducts
                article.showcase-prod-card
                  a.showcase-prod-img(href=`/products/${item.slug}`)
                    img(
                      alt="" 
                      src=item.avatar
                    )
                  .showcase-prod-info
                    h3
                      a(href=`/products/${item.slug}`) #{item.name}
                    .prod-price
                      span.price-old #{Number(item.priceOLD).toLocaleString('vi-VN')} ₫
                      span.price-new #{Number(item.priceNEW).toLocaleString('vi-VN')} ₫
                    button.btn.btn-gold-outline.button(onclick=`window.location.href='/products/${item.slug}'`) Xem Chi Tiết
          .showcase-banner
            .showcase-banner-inner
              img(
                alt="Nội thất phòng khách" 
                src="https://res.cloudinary.com/drakip2hi/image/upload/v1778223002/vvyau8e37a88ywijivwx.jpg"
                )
              .showcase-banner-caption
                a.showcase-link(href="/products") Xem thêm →
    // PRODUCT SHOWCASE 2: PHÒNG BẾP (reversed)
    section.section.showcase-section.bg-light
      .container
        .showcase-layout.reverse
          .showcase-banner
            .showcase-banner-inner
              img(
                alt="" 
                src="https://i.pinimg.com/1200x/b4/0f/43/b40f437944134d18871836f3843cb653.jpg"
                )
              .showcase-banner-caption
              
                a.showcase-link(href="/products/") Xem thêm →
          .showcase-products
            .section-head
              div
                p.section-eyebrow Phòng bếp
                h2.section-title Thanh Lịch & Tối Giản
              a.btn.btn-outline-dark.btn-sm(href="/products") Xem tất cả
            .showcase-prod-list
              each item in listKittchenProducts
                article.showcase-prod-card
                  a.showcase-prod-img(href=`/products/${item.slug}`)
                    img(
                      alt="" 
                      src=item.avatar
                      )
                  .showcase-prod-info
                    h3
                      a(href=`/products/${item.slug}`) #{item.name}
                    .prod-price
                      span.price-old #{Number(item.priceOLD).toLocaleString('vi-VN')} ₫
                      span.price-new #{Number(item.priceNEW).toLocaleString('vi-VN')} ₫
                    button.btn.btn-gold-outline(onclick=`window.location.href='/products/${item.slug}'`) Xem Chi Tiết
             
    // TESTIMONIALS
    section.section.testimonials-section
      .container
        .section-head.center
          p.section-eyebrow Đánh giá
          h2.section-title Khách hàng nói gì về chúng tôi
          p.section-desc Hơn 1.000 khách hàng đã hài lòng về dịch vụ và sản phẩm của chúng tôi
        .testimonials-grid
          article.testi-card
            .testi-stars ★★★★★
            blockquote.testi-text
              | "Mình thật sự rất hài lòng với sản phẩm đèn trang trí ở đây. Thiết kế đẹp, hiện đại và đúng như hình mô tả trên website. Sau khi lắp lên phòng khách thì không gian trở nên sang trọng và ấm cúng hơn rất nhiều. Ánh sáng dịu mắt, tạo cảm giác thư giãn vào buổi tối. Đóng gói kỹ, giao hàng nhanh và hỗ trợ khách hàng rất chuyên nghiệp."
            .testi-person
              img(
                alt="Anh Vũ" 
                src="/assets/images/av1.jpg"
                )
              div
                strong Anh Vũ
                span Đại diện công ty Forincon
          article.testi-card.featured
            .testi-stars ★★★★★
            blockquote.testi-text
              | "Ban đầu mình khá phân vân vì mua đèn online sợ chất lượng không như mong đợi, nhưng khi nhận hàng thì thật sự bất ngờ. Chất liệu chắc chắn, hoàn thiện tinh tế và cực kỳ sang trọng. Đội ngũ tư vấn hỗ trợ rất nhiệt tình, giúp mình chọn được mẫu phù hợp với phong cách nội thất của căn hộ. Chắc chắn mình sẽ tiếp tục ủng hộ trong những lần tới."
            .testi-person
              img(
                alt="Anh Mạnh" 
                src="/assets/images/av2.png"
                )
              div
                strong Anh Mạnh
                span Đại diện công ty ABC
          article.testi-card
            .testi-stars ★★★★★
            blockquote.testi-text
              | "Mình mua bộ đèn thả để trang trí cho quán cafe và kết quả vượt ngoài mong đợi. Không chỉ đẹp mà ánh sáng còn tạo cảm giác cực kỳ ấm áp, giúp không gian quán nổi bật và thu hút khách hơn hẳn. Rất nhiều khách đến quán đã hỏi xin địa chỉ mua đèn. Giá thành hợp lý so với chất lượng, chế độ bảo hành rõ ràng nên mình rất yên tâm sử dụng."
            .testi-person
              img(
                alt="Anh Quỳnh" 
                src="/assets/images/av3.jpg"
                )
              div
                strong Anh Quỳnh
                span Giám đốc công ty MDS
    // PROJECTS CAROUSEL
    section#projects.section.projects-section
      .container
        .section-head.space-between
          div
            p.section-eyebrow Dự án
            h2.section-title Không gian sống khác biệt
            p.section-desc(style="max-width:540px;")
              |   MANHQUYNH Decor cung cấp giải pháp tổng thể từ Kiến trúc tới nội
              |   thất đặc biệt là các dự án nội thất sang trọng hàng đầu tại Việt Nam.
          a.btn.btn-outline-dark(href="/products") Xem tất cả sản phẩm
      .proj-carousel-wrap
        #projCarousel.proj-carousel
          .proj-slide.active
            img(
              alt="" 
              src="/assets/images/banner2.png"
              )
            .proj-caption
              span.proj-tag Hiện Đại
              h3 Mát mắt với đèn bàn mang phong cách hiện đại
              a.proj-read-more(href="/products") Xem chi tiết →
          .proj-slide
            img(
              alt="" 
              src="/assets/images/banner3.png"
              )
            .proj-caption
              span.proj-tag Lung Linh
              h3 Lung linh với đèn chùm pha lê
              a.proj-read-more(href="/news") Xem chi tiết →
          .proj-slide
            img(
              alt="" 
              src="/assets/images/banner8.png"
              )
            .proj-caption
              span.proj-tag Độc đáo
              h3 Rực rỡ cùng đèn từ đồ tái chế
              a.proj-read-more(href="/news") Xem chi tiết →
          .proj-slide
            img(
              alt="Phong cách tối giản" 
              src="/assets/images/banner9.png"
              )
            .proj-caption
              span.proj-tag Tối giản
              h3 Mang phong cách cổ điển, tối giản vào căn nhà
              a.proj-read-more(href="/news") Xem chi tiết →
        button#projPrev.proj-arr.proj-prev(aria-label="Ảnh trước") ‹
        button#projNext.proj-arr.proj-next(aria-label="Ảnh tiếp") ›
        #projDots.proj-dots
          button.proj-dot.active(data-idx="0")
          button.proj-dot(data-idx="1")
          button.proj-dot(data-idx="2")
          button.proj-dot(data-idx="3")
    // NEWS / TIN TỨC
    section#blogs.section.news-section
      .container
        .section-head.space-between
          div
            p.section-eyebrow Blog
            h2.section-title Tin tức mới nhất
          a.btn.btn-outline-dark(href="/news") Xem tất cả →
        .news-grid
          article.news-card
            a.news-img-link(href="/news")
              img(
                alt="Design Talk" 
                src="https://i.pinimg.com/736x/da/d3/14/dad3149171dfe6677b48d1094d8c91d1.jpg"
                )
              span.news-cat Xu hướng
            .news-body
              .news-meta
                span 30/10/2024
                span 208 lượt xem
              h3
                a(href="/news") Design Talk – Chuyện trò về những xu hướng nội thất
              p
                | Xu hướng chính là những gì được nhiều người quan tâm đến trong một khoảng thời gian nhất định...
              a.news-read-more(href="/news") Đọc thêm →
          article.news-card
            a.news-img-link(href="/news")
              img(
                alt="" 
                src="https://i.pinimg.com/1200x/dc/66/ad/dc66ad86dacc9623e95cece2ed3e44a5.jpg"
                )
              span.news-cat Phong cách sống
            .news-body
              .news-meta
                span 30/10/2024
                span 195 lượt xem
              h3
                a(href="/news") Mang làn gió Lagom đến không gian sống của bạn
              p Lagom, một thuật ngữ không còn quá xa lạ với nhiều người. Phong cách sống "vừa đủ"...
              a.news-read-more(href="/news") Đọc thêm →
          article.news-card
            a.news-img-link(href="/news")
              img(
                alt="" 
                src="https://i.pinimg.com/736x/9d/09/99/9d099908f1874a14d247ddb99df7079a.jpg"
                )
              span.news-cat Vật liệu
            .news-body
              .news-meta
                span 30/10/2024
                span 196 lượt xem
              h3
                a(href="/news") Nội thất gỗ sồi – sự giao thoa của vẻ đẹp và chất lượng
              p Ngày nay, xu hướng tìm về với vẻ đẹp đơn giản, bền vững, gần gũi với thiên nhiên...
              a.news-read-more(href="/news") Đọc thêm →
    // LIVING SPACES (full-width image carousel)
    section.section.spaces-section
      .container
        .section-head.center
          p.section-eyebrow Không gian
          h2.section-title Không gian sống đơn giản, sang trọng
          p.section-desc
            | Khám phá những không gian sống được thiết kế để mang lại cảm giác thoải mái và hạnh
            |   phúc
      .spaces-carousel-wrap
        #spacesTrack.spaces-track
          .space-item.active(
            data-desc="Thiết kế tối giản với tông màu trung tính" 
            data-label="Phòng khách hiện đại"
            )
            img(
              alt="Phòng khách hiện đại" 
              src="/assets/images/banner5.png"
              )
          .space-item(
            data-desc="Không gian yên tĩnh, thư giãn cho gia đình" 
            data-label="Phòng ngủ sang trọng"
            )
            img(
              alt="Phòng ngủ sang trọng" 
              src="/assets/images/banner4.png"
              )
          .space-item(
            data-desc="Nơi gặp gỡ và chia sẻ những khoảnh khắc ấm áp" 
            data-label="Khu vực ăn uống"
            )
            img(
              alt="Khu ăn uống" 
              src="/assets/images/banner6.png"
              )
          .space-item(
            data-desc="Không gian tập trung, sáng tạo tuyệt vời" 
            data-label="Góc làm việc"
            )
            img(
              alt="Góc làm việc" 
              src="/assets/images/banner7.png"
              )
        #spacesInfo.spaces-info
          h3#spaceLabel Phòng khách hiện đại
          p#spaceDesc Thiết kế tối giản với tông màu trung tính
        button#spacePrev.space-arr.space-prev ‹
