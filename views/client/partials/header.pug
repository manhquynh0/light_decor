            stroke-width="2" 
            stroke="currentColor" 
            fill="none" 
            viewBox="0 0 24 24" 
            height="20" 
            width="20"
          )
            path(d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2")
            circle(r="4" cy="7" cx="12")
        
  
